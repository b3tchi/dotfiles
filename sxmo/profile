#!/bin/sh
# sxmo profile for Nothing Phone 1 (spacewar)
# Deployed to: ~/.config/sxmo/profile

# shellcheck source=scripts/core/sxmo_common.sh
. sxmo_common.sh

# Browser
command -v firefox >/dev/null && export BROWSER=firefox

# Terminal
export TERMCMD="sxmo_terminal.sh"

# Display scale (device profile defaults to 3, we override to 2)
# 1080x2400 / 2 = 540x1200 effective
export SXMO_SWAY_SCALE=2

# Ringtone / notifications
export SXMO_RINGTONE="$(xdg_data_path sxmo/ring.ogg)"
export SXMO_TEXTSOUND="$(xdg_data_path sxmo/notify.ogg)"
export SXMO_RINGTIME=20
export SXMO_RINGNUMBER=10

# Default SMS draft text
export SXMO_DEFAULT_DRAFT="Enter new message here."

# WORKAROUND: Disable lock/screenoff states
# Power button lock cycle breaks Clicks Creator Keyboard (USB HID 13614:8966).
# After locking and unlocking, the keyboard stops responding entirely.
# Only use unlock state (no lock, no screenoff).
export SXMO_STATES="unlock"
export SXMO_SUSPENDABLE_STATES=""

# Wallpaper
export SXMO_BG_IMG="$HOME/.config/sxmo/wallpaper.jpg"

