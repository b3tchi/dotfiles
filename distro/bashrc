#
# ~/.bashrc
#

# Always ensure ~/.local/bin is in PATH (non-interactive shells too)
export PATH="$HOME/.local/bin:$PATH"

# bd (beads) - shared dolt sql-server across all repos (one server, port 3308)
# instead of default per-repo random-port server. State: ~/.beads/shared-server/
export BEADS_DOLT_SERVER_MODE=1
export BEADS_DOLT_SHARED_SERVER=1

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

# Inside zellij, wrap a tmux session dedicated to this zellij session.
# NOT the shared `local` group used by other terminals — two clients on the
# same grouped windows clamp to the smallest client's size and blank the web
# client. A per-zellij session keeps sizing independent.
if [[ -n "$ZELLIJ" ]]; then
	# A zellij pane never legitimately inherits TMUX. If it's set, it leaked
	# from whatever launched the web server (e.g. a tmux'd shell baking TMUX
	# into the daemon env). Clear it so tmux-start doesn't think we're already
	# in tmux and bail — otherwise the pane drops to plain bash, no wrapping.
	unset TMUX
	command -v tmux-start &>/dev/null && tmux-start attach 0 "zj_${ZELLIJ_SESSION_NAME}"
# Auto-start tmux session (script symlinked to ~/.local/bin via rotz)
elif command -v tmux-start &>/dev/null; then
	if [[ -n "$TMUX_TARGET" ]]; then
		# Pre-created session:window — attach, drop to bash on detach
		# ^thin_ prefix → attach via -L thin socket; otherwise default server
		if [[ "$TMUX_TARGET" =~ ^thin_ ]]; then
			tmux -L thin attach-session -t "$TMUX_TARGET"
		else
			tmux attach-session -t "$TMUX_TARGET"
		fi
	else
		# Detect WM project workspace to align tmux session group with project
		PROJECT=""
		ws_name=""
		if command -v wm-ipc.nu &>/dev/null; then
			ws_name=$(nu -c 'use ~/.local/bin/wm-ipc.nu *; ipc "-t get_workspaces" | from json | where focused == true | first | get name' 2>/dev/null)
			# Match numbered project workspace: <name>_<digits>
			if [[ "$ws_name" =~ ^(.+)_[0-9]+$ ]]; then
				PROJECT="${BASH_REMATCH[1]}"
			# Match bare project name (non-numeric, check against projects.yaml)
			elif [[ -n "$ws_name" && ! "$ws_name" =~ ^[0-9]+$ ]]; then
				config="$HOME/.config/project/projects.yaml"
				if [[ -f "$config" ]] && grep -q "^  ${ws_name}:" "$config" 2>/dev/null; then
					PROJECT="$ws_name"
				fi
			fi
		fi

		if [[ -n "$PROJECT" ]]; then
			export PROJECT
			tmux-start attach 0 "$PROJECT"
		else
			tmux-start attach 0 local
		fi
	fi
fi
