node_modules/
.mypy_cache/
__pycache__/
*.pyc
resources/
*.sh.log
raspberry/pi_image/
nvim/test_*
flow-launcher/Plugins/*/*.json.bak
power-toys/**/Logs
nushell/scripts/gwt/config/profiles.yaml

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Perles per-project config (use global ~/.config/perles/config.yaml)
.perles/

# SSH per-host configs (per-machine, not tracked; .gitkeep preserves dir)
ssh/config.d/*
!ssh/config.d/.gitkeep

# Eval sandboxes (each seed re-creates a throwaway git repo)
claude/marketplace/plugins/infinifu/skills/*-workspace/iteration-*/eval-*/with_skill/sandbox/
claude/marketplace/plugins/infinifu/skills/*-workspace/iteration-*/eval-*/without_skill/sandbox/
