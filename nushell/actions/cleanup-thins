#!/usr/bin/env nu
# cleanup-thins: remove thin sessions not attached to any sway workspace
# Uses wm-state list and tmux-to-workstation list, joins on session

def main [
    --dry-run (-n)  # Show what would be killed without doing it
] {
    # Get thin sessions from wm-state (those on a sway workspace)
    let wm = (do { wm-state list } | complete)
    let parsed = if $wm.exit_code == 0 and ($wm.stdout | is-not-empty) {
        try { $wm.stdout | from yaml } catch { null }
    } else { null }
    let attached_sessions = if ($parsed != null) and (($parsed | describe) | str starts-with "record") {
        $parsed.workspaces? | default [] | each {|ws|
            $ws.state | transpose _ entry | get entry
            | where {|e| ($e | get -o session_type | default "") == "thin" }
            | get -o session
        } | flatten | compact
    } else { [] }

    # Get all thin sessions from tmux-to-workstation
    let all_thins = (do { tmux-to-workstation list } | complete)
    let parsed_thins = if $all_thins.exit_code == 0 and ($all_thins.stdout | is-not-empty) {
        try { $all_thins.stdout | from yaml } catch { null }
    } else { null }
    let parsed_kind = if $parsed_thins != null { ($parsed_thins | describe) } else { "" }
    let thin_sessions = if ($parsed_thins != null) and (($parsed_kind | str starts-with "table") or ($parsed_kind | str starts-with "list")) {
        $parsed_thins | each {|e| $e | get -o session } | compact
    } else {
        print "No thin sessions"
        return
    }

    # Thin sessions not on any workspace
    let orphans = $thin_sessions | where {|s| $s not-in $attached_sessions }

    if ($orphans | is-empty) {
        print "No orphaned thin sessions"
        return
    }

    for orphan in $orphans {
        if $dry_run {
            print $"Would kill: ($orphan)"
        } else {
            tmux -L thin kill-session -t $orphan
            print $"Killed: ($orphan)"
        }
    }
}
