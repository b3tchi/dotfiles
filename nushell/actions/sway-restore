#!/usr/bin/env nu
# Restore sway workspaces + terminals from saved state after sway restart
# Uses TMUX_TARGET to pre-create sessions and attach terminals to the right window

def main [] {
    let state_file = ("~/.cache/sway-state.json" | path expand)
    if not ($state_file | path exists) {
        print "No saved state found"
        return
    }

    let state = (open $state_file)
    let workspaces = ($state | get -o workspaces | default [])

    if ($workspaces | is-empty) {
        print "No workspaces to restore"
        return
    }

    # Check if tmux is running (sessions must survive for restore to be useful)
    if (tmux list-sessions | complete | get exit_code) != 0 {
        print "No tmux sessions running, skipping restore"
        return
    }

    for ws in $workspaces {
        let ws_name = ($ws | get -o name | default "")
        if ($ws_name | is-empty) { continue }

        let terminals = ($ws | get -o terminals | default [])

        print $"Restoring workspace: ($ws_name)"
        ^swaymsg $"workspace ($ws_name)"

        if ($terminals | is-empty) {
            ^swaymsg exec foot
            continue
        }

        for term in $terminals {
            let session = ($term | get -o session | default "local")
            let window = ($term | get -o window | default null)

            # Create headless tmux session+window for this terminal
            let target = (tmux-start start 0 $session | str trim)

            if $window != null {
                # Parse session name from target (e.g. "local_3:5" -> "local_3")
                let target_session = ($target | split row ":" | first)
                tmux select-window -t $"($target_session):($window)"
            }

            ^swaymsg $"exec env TMUX_TARGET=($target) foot"
        }
    }

    # Switch back to first workspace
    let first_name = ($workspaces | first | get -o name | default "")
    if ($first_name | is-not-empty) {
        ^swaymsg $"workspace ($first_name)"
    }

    print "Restore complete"
}
