#!/usr/bin/env nu
# preview-test — scripted test for the preview wrapper (akm-graph-test /
# d2-router-test pattern)
#
# Tests:
#   1. Idempotent lifecycle: start → start (no-op) → status → stop → status,
#      against a fake preview-d that serves a minimal /status + /stop.
#   2. Stale pidfile: bogus dead pid → cleaned + relaunch.
#   3. Missing binary → error names "rotz install preview".
#   4. `preview status` against a stopped daemon returns a clean
#      "not running" message (not a stack trace) — sp008 Task 1 test_plan.
#   5. `preview send <path> --window N` POSTs {"path": <path>} to
#      /preview<N> — sp008 Task 5 test_plan.
#   6. `preview send <path>` with no --window defaults to window 1 (sp008
#      Task 5 success criteria: "pick a sane default").
#   7. `preview register <addr>` POSTs {"nvim": <addr>} to /register and
#      prints the slot parsed from the daemon's {"slot": N} response —
#      sp009 Task 3 test_plan ("wrapper test: `preview register` posts the
#      addr and parses `slot` from the response").
#   8. `preview register <addr> --slot N` includes {"slot": N} in the
#      request body (the plugin's idempotent-rebind path, sp009 Task 3).
#   9. `preview start` blocks until the daemon answers /status, so a
#      register fired immediately after start (nvim :PreviewStart's exact
#      sequence) cannot hit connection-refused (dotfiles-nbt).
#
# Run:  nu nushell/actions/preview-test
# Pass: exits 0 and prints "PASS: 9 tests passed"
# Fail: exits 1 and prints "FAIL: <description>"

# Self-locate the wrapper relative to this test so it survives merging out
# of the author's worktree (no hardcoded paths).
const WRAPPER = (path self | path dirname | path join "preview")

# ── setup ─────────────────────────────────────────────────────────────────────

let tmp = (^mktemp -d | str trim)
let fake_bin_dir = $"($tmp)/bin"
let cache_dir = $"($tmp)/.cache/preview"
let pid_file = $"($cache_dir)/pid"
let fake_daemon = $"($fake_bin_dir)/preview-d"
let launched_marker = $"($tmp)/daemon_launched"

^mkdir -p $fake_bin_dir
^mkdir -p $cache_dir

# Test port far from the 4200 default and common services.
let test_port = "58920"
let test_path = ([$fake_bin_dir "/usr/local/bin" "/usr/bin" "/bin" "/sbin"] | str join ":")

# Fake preview-d: a tiny python HTTP server answering GET /status and
# POST /stop (exits on stop), plus POST /preview<N> which captures the
# request path + body to $CAPTURE_FILE (sp008 Task 5 test_plan: assert the
# `send` verb's POST against a stub server capturing the body). Records
# that it was launched.
let fake_src = "#!/bin/bash
touch " + $launched_marker + "
exec python3 - \"$@\" <<'PY'
import sys, os, json, time
from http.server import BaseHTTPRequestHandler, HTTPServer
time.sleep(float(os.environ.get('STARTUP_DELAY', '0')))
port = int(os.environ.get('PREVIEW_PORT', '4200'))
capture_file = os.environ.get('CAPTURE_FILE', '')
class H(BaseHTTPRequestHandler):
    def log_message(self, *a): pass
    def do_GET(self):
        if self.path == '/status':
            body = json.dumps({'pid': os.getpid(), 'root': '/fake',
                               'port': str(port),
                               'started_at': '2026-01-01T00:00:00Z'}).encode()
            self.send_response(200); self.send_header('Content-Type','application/json')
            self.send_header('Content-Length', str(len(body))); self.end_headers()
            self.wfile.write(body)
        else:
            self.send_response(404); self.end_headers()
    def do_POST(self):
        if self.path == '/stop':
            self.send_response(200); self.send_header('Content-Length','0'); self.end_headers()
            def die(): os._exit(0)
            import threading; threading.Timer(0.1, die).start()
        elif self.path.startswith('/preview') and capture_file:
            length = int(self.headers.get('Content-Length', 0))
            raw = self.rfile.read(length)
            with open(capture_file, 'w') as f:
                f.write(self.path + '\\n' + raw.decode())
            resp = raw if raw else b'{}'
            self.send_response(200); self.send_header('Content-Type','application/json')
            self.send_header('Content-Length', str(len(resp))); self.end_headers()
            self.wfile.write(resp)
        elif self.path == '/register':
            length = int(self.headers.get('Content-Length', 0))
            raw = self.rfile.read(length)
            if capture_file:
                with open(capture_file, 'w') as f:
                    f.write(self.path + '\\n' + raw.decode())
            data = json.loads(raw.decode()) if raw else {}
            slot = data.get('slot', 7)
            body = json.dumps({'slot': slot}).encode()
            self.send_response(200); self.send_header('Content-Type','application/json')
            self.send_header('Content-Length', str(len(body))); self.end_headers()
            self.wfile.write(body)
        else:
            self.send_response(404); self.end_headers()
HTTPServer(('127.0.0.1', port), H).serve_forever()
PY
"
$fake_src | save --force $fake_daemon
^chmod +x $fake_daemon

# Helper: run the wrapper with a clean env (isolated HOME/PATH/port).
def run-wrapper [tmp: string, port: string, path: string, verb: string, extra_args: string = ""] {
    do {
        ^bash -c $"HOME=($tmp) PREVIEW_PORT=($port) PREVIEW_ROOT=($tmp) PATH=($path) /usr/bin/nu ($WRAPPER) ($verb) ($extra_args)"
    } | complete
}

# Helper: start the fake daemon with CAPTURE_FILE set so POST /preview<N>
# bodies land in $capture_file, and wait for it to come up.
def start-with-capture [tmp: string, port: string, path: string, capture_file: string] {
    let r = (do {
        ^bash -c $"HOME=($tmp) PREVIEW_PORT=($port) PREVIEW_ROOT=($tmp) PATH=($path) CAPTURE_FILE=($capture_file) /usr/bin/nu ($WRAPPER) start"
    } | complete)
    if $r.exit_code != 0 {
        print $"FAIL: capture-mode start exited ($r.exit_code)\n($r.stdout)($r.stderr)"
        exit 1
    }
    for _ in 1..30 {
        let up = (do { ^bash -c $"curl -sf --max-time 1 http://127.0.0.1:($port)/status" } | complete)
        if $up.exit_code == 0 { return }
        sleep 100ms
    }
}

def wait-port-free [port: string] {
    for _ in 1..30 {
        let up = (do { ^bash -c $"curl -sf --max-time 1 http://127.0.0.1:($port)/status" } | complete)
        if $up.exit_code != 0 { return }
        sleep 100ms
    }
}

# ── test 1: idempotent lifecycle ──────────────────────────────────────────────

let r1 = (run-wrapper $tmp $test_port $test_path "start")
if $r1.exit_code != 0 {
    print $"FAIL: first start exited ($r1.exit_code)\n($r1.stdout)($r1.stderr)"
    exit 1
}
if not ($launched_marker | path exists) {
    print "FAIL: fake daemon not launched on first start"
    exit 1
}
# Wait for the fake daemon to bind.
for _ in 1..30 {
    let up = (do { ^bash -c $"curl -sf --max-time 1 http://127.0.0.1:($test_port)/status" } | complete)
    if $up.exit_code == 0 { break }
    sleep 100ms
}

# Second start must be a no-op (port-probe short-circuit), still exit 0.
let r2 = (run-wrapper $tmp $test_port $test_path "start")
if $r2.exit_code != 0 {
    print $"FAIL: second start exited ($r2.exit_code)"
    exit 1
}
if not ($"($r2.stdout)($r2.stderr)" | str contains "no-op") {
    print $"FAIL: second start did not report no-op:\n($r2.stdout)($r2.stderr)"
    exit 1
}

# status must report the daemon's fields — the parsed snapshot (sp008
# Task 1 test_plan: `preview status` against a running daemon).
let rs = (run-wrapper $tmp $test_port $test_path "status")
if not ($"($rs.stdout)" | str contains "started_at") {
    print $"FAIL: status did not surface daemon fields:\n($rs.stdout)($rs.stderr)"
    exit 1
}

# stop must bring it down.
let rstop = (run-wrapper $tmp $test_port $test_path "stop")
if $rstop.exit_code != 0 {
    print $"FAIL: stop exited ($rstop.exit_code)"
    exit 1
}
wait-port-free $test_port

# status after stop must report a clean "not running" message, not a stack
# trace (sp008 Task 1 test_plan).
let rs2 = (run-wrapper $tmp $test_port $test_path "status")
if $rs2.exit_code != 0 {
    print $"FAIL: status after stop should exit 0 with a clean message, not an error:\n($rs2.stdout)($rs2.stderr)"
    exit 1
}
if not ($"($rs2.stdout)($rs2.stderr)" | str contains "not running") {
    print $"FAIL: status after stop should report not running:\n($rs2.stdout)($rs2.stderr)"
    exit 1
}
if ($"($rs2.stdout)($rs2.stderr)" | str contains "Error:") or ($"($rs2.stdout)($rs2.stderr)" | str contains "panic") {
    print $"FAIL: status after stop leaked a stack trace:\n($rs2.stdout)($rs2.stderr)"
    exit 1
}
^rm -f $pid_file $launched_marker
print "PASS: idempotent lifecycle start/start/status/stop/status"

# ── test 2: stale pidfile → cleaned + relaunch ────────────────────────────────

let bogus_pid = 9999993
if (do { ^kill -0 $bogus_pid } | complete | get exit_code) == 0 {
    print $"FAIL: bogus pid ($bogus_pid) unexpectedly alive"
    exit 1
}
$bogus_pid | into string | save --force $pid_file

let r3 = (run-wrapper $tmp $test_port $test_path "start")
if $r3.exit_code != 0 {
    print $"FAIL: start with stale pidfile exited ($r3.exit_code)\n($r3.stdout)($r3.stderr)"
    exit 1
}
let new_pid = (try { open $pid_file | str trim | into int } catch { -1 })
if $new_pid == $bogus_pid or $new_pid <= 0 {
    print $"FAIL: stale pidfile not replaced, pid ($new_pid)"
    exit 1
}
# Bring the relaunched daemon down.
for _ in 1..30 {
    let up = (do { ^bash -c $"curl -sf --max-time 1 http://127.0.0.1:($test_port)/status" } | complete)
    if $up.exit_code == 0 { break }
    sleep 100ms
}
run-wrapper $tmp $test_port $test_path "stop" | ignore
wait-port-free $test_port
^rm -f $pid_file $launched_marker
print "PASS: stale pidfile cleaned and daemon relaunched"

# ── test 3: missing binary → error names 'rotz install preview' ───────────────

^rm -f $fake_daemon
let no_daemon_path = "/usr/local/bin:/usr/bin:/bin:/sbin"
let r4 = (run-wrapper $tmp $test_port $no_daemon_path "start")
if $r4.exit_code == 0 {
    print "FAIL: start should fail when daemon binary is missing"
    exit 1
}
if not ($"($r4.stdout)($r4.stderr)" | str contains "rotz install preview") {
    print $"FAIL: missing-binary error does not name 'rotz install preview':\n($r4.stdout)($r4.stderr)"
    exit 1
}
print "PASS: missing binary names 'rotz install preview'"

# ── test 4: double stop is idempotent (never running at all) ──────────────────

^rm -f $pid_file
let r5 = (run-wrapper $tmp $test_port $no_daemon_path "stop")
if $r5.exit_code != 0 {
    print $"FAIL: stop with no daemon running should exit 0 (idempotent):\n($r5.stdout)($r5.stderr)"
    exit 1
}
print "PASS: stop against a never-started daemon is idempotent"

# ── test 5: send verb POSTs {path} to /preview<N> ─────────────────────────────

# Test 3 removed the fake daemon binary — restore it for the remaining tests.
$fake_src | save --force $fake_daemon
^chmod +x $fake_daemon

let capture_file = $"($tmp)/capture.txt"
let send_path = $"($tmp)/some/file.md"
^mkdir -p $"($tmp)/some"
"# hello" | save --force $send_path

start-with-capture $tmp $test_port $test_path $capture_file

let rsend = (run-wrapper $tmp $test_port $test_path "send" $"($send_path) --window 2")
if $rsend.exit_code != 0 {
    print $"FAIL: send exited ($rsend.exit_code)\n($rsend.stdout)($rsend.stderr)"
    exit 1
}
if not ($capture_file | path exists) {
    print $"FAIL: send did not reach the fake daemon (no capture file):\n($rsend.stdout)($rsend.stderr)"
    exit 1
}
let captured = (open $capture_file)
if not ($captured | str contains "/preview2") {
    print $"FAIL: send did not POST to /preview2:\n($captured)"
    exit 1
}
if not ($captured | str contains $send_path) {
    print $"FAIL: send body did not contain the path:\n($captured)"
    exit 1
}
run-wrapper $tmp $test_port $test_path "stop" | ignore
wait-port-free $test_port
^rm -f $pid_file $launched_marker $capture_file
print "PASS: send verb POSTs {path} to /preview<N>"

# ── test 6: send with no --window defaults to window 1 ────────────────────────

start-with-capture $tmp $test_port $test_path $capture_file

let rsend2 = (run-wrapper $tmp $test_port $test_path "send" $send_path)
if $rsend2.exit_code != 0 {
    print $"FAIL: default-window send exited ($rsend2.exit_code)\n($rsend2.stdout)($rsend2.stderr)"
    exit 1
}
if not ($capture_file | path exists) {
    print $"FAIL: default-window send did not reach the fake daemon:\n($rsend2.stdout)($rsend2.stderr)"
    exit 1
}
let captured2 = (open $capture_file)
if not ($captured2 | str contains "/preview1") {
    print $"FAIL: default-window send did not POST to /preview1:\n($captured2)"
    exit 1
}
run-wrapper $tmp $test_port $test_path "stop" | ignore
wait-port-free $test_port
^rm -f $pid_file $launched_marker $capture_file
print "PASS: send with no --window defaults to window 1"

# ── test 7: register POSTs {nvim} to /register and parses `slot` ─────────────

start-with-capture $tmp $test_port $test_path $capture_file

let nvim_addr = "/tmp/nvim.fake.sock"
let rreg = (run-wrapper $tmp $test_port $test_path "register" $nvim_addr)
if $rreg.exit_code != 0 {
    print $"FAIL: register exited ($rreg.exit_code)\n($rreg.stdout)($rreg.stderr)"
    exit 1
}
if not ($capture_file | path exists) {
    print $"FAIL: register did not reach the fake daemon \(no capture file\):\n($rreg.stdout)($rreg.stderr)"
    exit 1
}
let captured_reg = (open $capture_file)
if not ($captured_reg | str contains "/register") {
    print $"FAIL: register did not POST to /register:\n($captured_reg)"
    exit 1
}
if not ($captured_reg | str contains $nvim_addr) {
    print $"FAIL: register body did not contain the nvim address:\n($captured_reg)"
    exit 1
}
# The fake daemon echoes back {"slot": 7} when no slot is given in the body.
if ($rreg.stdout | str trim) != "7" {
    print $"FAIL: register did not print the parsed slot from the response:\n($rreg.stdout)($rreg.stderr)"
    exit 1
}
run-wrapper $tmp $test_port $test_path "stop" | ignore
wait-port-free $test_port
^rm -f $pid_file $launched_marker $capture_file
print "PASS: register POSTs {nvim} to /register and parses slot from the response"

# ── test 8: register --slot N includes {slot: N} in the request body ─────────

start-with-capture $tmp $test_port $test_path $capture_file

let rreg2 = (run-wrapper $tmp $test_port $test_path "register" $"($nvim_addr) --slot 4")
if $rreg2.exit_code != 0 {
    print $"FAIL: register --slot exited ($rreg2.exit_code)\n($rreg2.stdout)($rreg2.stderr)"
    exit 1
}
let captured_reg2 = (open $capture_file)
if not ($captured_reg2 | str contains '"slot": 4') {
    print $"FAIL: register --slot 4 did not include slot in the request body:\n($captured_reg2)"
    exit 1
}
# The fake daemon echoes back whichever slot it was given.
if ($rreg2.stdout | str trim) != "4" {
    print $"FAIL: register --slot 4 did not print slot 4 back:\n($rreg2.stdout)($rreg2.stderr)"
    exit 1
}
run-wrapper $tmp $test_port $test_path "stop" | ignore
wait-port-free $test_port
^rm -f $pid_file $launched_marker $capture_file
print "PASS: register --slot N includes {slot: N} in the request body"

# ── test 9: start blocks until daemon ready (register-after-start race) ──────

# The fake daemon delays its bind by STARTUP_DELAY seconds; start must not
# return before /status answers, so the register fired straight after it
# (nvim :PreviewStart's exact sequence, dotfiles-nbt) succeeds without any
# retry on the caller's side.
let r9 = (do {
    ^bash -c $"HOME=($tmp) PREVIEW_PORT=($test_port) PREVIEW_ROOT=($tmp) PATH=($test_path) STARTUP_DELAY=1 /usr/bin/nu ($WRAPPER) start"
} | complete)
if $r9.exit_code != 0 {
    print $"FAIL: start against slow-boot daemon exited ($r9.exit_code)\n($r9.stdout)($r9.stderr)"
    exit 1
}
let rreg9 = (run-wrapper $tmp $test_port $test_path "register" $nvim_addr)
if $rreg9.exit_code != 0 {
    print $"FAIL: register immediately after start hit a not-ready daemon — start returned before /status answered:\n($rreg9.stdout)($rreg9.stderr)"
    exit 1
}
run-wrapper $tmp $test_port $test_path "stop" | ignore
wait-port-free $test_port
^rm -f $pid_file $launched_marker
print "PASS: start blocks until the daemon answers, register-after-start is race-free"

# ── cleanup ───────────────────────────────────────────────────────────────────

^rm -rf $tmp
print ""
print "PASS: 9 tests passed"
