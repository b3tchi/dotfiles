    print $"FAIL: window spawn over a recycled pid did not report stale cleanup:\n($r13.stdout)($r13.stderr)"
    exit 1
}
if not (pid-is-alive $bystander_pid) {
    print $"FAIL: recycled/bystander pid ($bystander_pid) was killed — anti-pattern violated \(cmdline was never verified\)"
    exit 1
}
let win1_pid_v3 = (open $win1_pid_file | str trim | into int)
if $win1_pid_v3 == $bystander_pid or not (wait-pid-alive $win1_pid_v3) {
