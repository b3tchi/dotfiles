#!/usr/bin/env nu
# wm-state: list, save, and restore workspace ↔ tmux session mappings
# Works under sway (Wayland) and i3 (X11).

const wm_ipc = '~/.local/bin/wm-ipc.nu'
use $wm_ipc *

# Terminal identifiers to match (sway app_id or i3 window_properties.class).
const terminal_ids = ["foot", "kitty", "wezterm", "WezTerm", "Alacritty", "alacritty", "xterm"]

# Default terminal to launch per WM on restore.
const default_term_by_wm = { sway: "foot", i3: "kitty" }

# Check if candidate_pid is a descendant of ancestor_pid via /proc
def is-descendant [ancestor_pid: int, candidate_pid: int] {
    mut pid = $candidate_pid
    loop {
        if $pid == $ancestor_pid { return true }
        if $pid <= 1 { return false }
        let ppid_file = $"/proc/($pid)/stat"
        if not ($ppid_file | path exists) { return false }
        let stat = (open $ppid_file --raw)
        let after_comm = ($stat | str index-of ")" | $in + 2)
        let fields = ($stat | str substring $after_comm.. | str trim | split row -r '\s+')
        $pid = ($fields | get 1 | into int)
    }
}

# Resolve pid for an i3 window via xprop _NET_WM_PID.
# i3 tree does not include pid on window nodes; sway does.
def resolve-i3-pid [window_id: int] {
    if $window_id <= 0 { return 0 }
    let r = (do { ^xprop -id $window_id _NET_WM_PID } | complete)
    if $r.exit_code != 0 { return 0 }
    let line = ($r.stdout | str trim)
    # Format: "_NET_WM_PID(CARDINAL) = 12345"
    let parts = ($line | split row "=")
    if ($parts | length) < 2 { return 0 }
    try { $parts | last | str trim | into int } catch { 0 }
}

# Identify whether a tree node is a recognized terminal, returning its pid (or 0).
def node-terminal-pid [node: record] {
    let app_id = ($node | get -o app_id | default "")
    let cls = ($node | get -o window_properties.class | default "")
    let matches = ($terminal_ids | any {|t| $t == $app_id or $t == $cls })
    if not $matches { return 0 }
    let pid = ($node | get -o pid | default 0)
    if $pid > 0 { return $pid }
    # i3 path: resolve via xprop on the X11 window id
    let win = ($node | get -o window | default 0)
    resolve-i3-pid $win
}

# Recursively collect terminal PIDs from a WM tree node (sway or i3)
def collect-term-pids [node: record] {
    mut pids = []
    let pid = (node-terminal-pid $node)
    if $pid > 0 { $pids = ($pids | append $pid) }
    for child in ($node | get -o nodes | default []) {
        $pids = ($pids | append (collect-term-pids $child))
    }
    for child in ($node | get -o floating_nodes | default []) {
        $pids = ($pids | append (collect-term-pids $child))
    }
    $pids
}

# Resolve a window node's class / app_id identifier (leaf label).
def node-class [node: record] {
    let aid = ($node | get -o app_id | default "")
    if ($aid | is-not-empty) { return $aid }
    ($node | get -o window_properties.class | default "")
}

# Allocate a unique child-key in a container body. Numeric strings are leaf ids;
# string keys are layout types — if duplicate, uniquify by appending -2, -3, ...
def uniq-container-key [base: string, body: record] {
    if not ($base in ($body | columns)) { return $base }
    mut n = 2
    loop {
        let cand = $"($base)-($n)"
        if not ($cand in ($body | columns)) { return $cand }
        $n = $n + 1
    }
}

# Recursive layout + state builder for a single tree node.
# Returns:
#   { kind: "leaf", id: int, class: string, state: { "<id>": {...} }, next_id: int } OR
#   { kind: "container", layout_type: string, body: record, state: record, next_id: int } OR
#   { kind: "empty", next_id: int }
def build-layout-state [node: record, id_start: int] {
    let children = ($node | get -o nodes | default [])
    let wid = ($node | get -o window | default 0)

    if ($children | is-empty) {
        if $wid <= 0 {
            return { kind: "empty", next_id: $id_start }
        }
        let id = $id_start
        let cls = (node-class $node)
        let pid_raw = ($node | get -o pid | default 0)
        let pid = if $pid_raw > 0 { $pid_raw } else { resolve-i3-pid $wid }
        # Capture the WM window title verbatim. Restore-side will escape regex
        # metacharacters when building swallow patterns; saved value is raw.
        let title = ($node | get -o name | default "")
        let key = ($id | into string)
        return {
            kind: "leaf",
            id: $id,
            class: $cls,
            state: { $key: { wid: $wid, pid: $pid, class: $cls, title: $title } },
            next_id: ($id + 1),
        }
    }

    # Container
    let layout_type = ($node | get -o layout | default "splith")
    mut body = {}
    mut state = {}
    mut id = $id_start
    for c in $children {
        let r = (build-layout-state $c $id)
        $id = $r.next_id
        if $r.kind == "empty" { continue }
        if $r.kind == "leaf" {
            $state = ($state | merge $r.state)
            $body = ($body | upsert ($r.id | into string) $r.class)
        } else {
            # Nested container
            $state = ($state | merge $r.state)
            let key = (uniq-container-key $r.layout_type $body)
            $body = ($body | upsert $key $r.body)
        }
    }
    { kind: "container", layout_type: $layout_type, body: $body, state: $state, next_id: $id }
}

# Build layout record + state record for a workspace node. IDs are 1..N across the
# workspace in traversal order.
def build-workspace-layout [ws: record] {
    let layout_type = ($ws | get -o layout | default "splith")
    let children = ($ws | get -o nodes | default [])
    mut body = {}
    mut state = {}
    mut id = 1
    for c in $children {
        let r = (build-layout-state $c $id)
        $id = $r.next_id
        if $r.kind == "empty" { continue }
        if $r.kind == "leaf" {
            $state = ($state | merge $r.state)
            $body = ($body | upsert ($r.id | into string) $r.class)
        } else {
            $state = ($state | merge $r.state)
            let key = (uniq-container-key $r.layout_type $body)
            $body = ($body | upsert $key $r.body)
        }
    }
    { layout: { $layout_type: $body }, state: $state }
}

# Recursively find all workspace nodes in the WM tree.
# Sway: output -> workspace. i3: output -> "content" con -> workspace.
def find-workspaces [node: record] {
    mut out = []
    if ($node | get -o type | default "") == "workspace" {
        let name = ($node | get -o name | default "")
        if $name != "__i3_scratch" {
            $out = ($out | append $node)
        }
    }
    for child in ($node | get -o nodes | default []) {
        $out = ($out | append (find-workspaces $child))
    }
    for child in ($node | get -o floating_nodes | default []) {
        $out = ($out | append (find-workspaces $child))
    }
    $out
}

# Get workspace records with layout tree + state record (WM-agnostic).
def get-wm-workspaces [] {
    let tree_json = (ipc "-t get_tree")
    if $tree_json == null { return [] }
    let tree = ($tree_json | from json)
    find-workspaces $tree | each { |ws|
        let ls = (build-workspace-layout $ws)
        { workspace: ($ws | get name), layout: $ls.layout, state: $ls.state }
    } | where { |r| (($r.state | columns) | length) > 0 }
}

# Find tmux client info for a foot PID against local (fat) clients
def find-tmux-client [foot_pid: int, clients: list<record>] {
    for client in $clients {
        if (is-descendant $foot_pid $client.pid) {
            return { type: "local", session: $client.session }
        }
    }
    return {}
}

# Find thin tmux client info for a foot PID
def find-thin-client [foot_pid: int, thin_clients: list<record>] {
    for client in $thin_clients {
        if (is-descendant $foot_pid $client.pid) {
            return { type: "thin", session: $client.session }
        }
    }
    return {}
}

# Recursively enumerate window leaves under a WM tree node.
# Walks both nodes and floating_nodes so floating windows are visible to matching.
# Returns: [{wid, class, pid, path, floating}, ...]
def collect-ws-windows [node: record, path_prefix: string] {
    let children = ($node | get -o nodes | default [])
    let floats = ($node | get -o floating_nodes | default [])
    if ($children | is-empty) and ($floats | is-empty) {
        let wid = ($node | get -o window | default 0)
        if $wid > 0 {
            let cls = (node-class $node)
            let pid_raw = ($node | get -o pid | default 0)
            let pid = if $pid_raw > 0 { $pid_raw } else { resolve-i3-pid $wid }
            return [{ wid: $wid, class: $cls, pid: $pid, path: $path_prefix, floating: false }]
        }
        return []
    }
    mut out = []
    for i in 0..<($children | length) {
        let c = ($children | get $i)
        let sub = if ($path_prefix | is-empty) { $"($i)" } else { $"($path_prefix).($i)" }
        $out = ($out | append (collect-ws-windows $c $sub))
    }
    # Floating descendants — mark floating=true for all leaves found through this branch.
    for i in 0..<($floats | length) {
        let c = ($floats | get $i)
        let sub = if ($path_prefix | is-empty) { $"f($i)" } else { $"($path_prefix).f($i)" }
        let leaves = (collect-ws-windows $c $sub)
        $out = ($out | append ($leaves | each {|l| $l | upsert floating true }))
    }
    $out
}

# Find the workspace tree node by name (null if none).
def find-workspace-by-name [tree: record, name: string] {
    let all_ws = (find-workspaces $tree)
    let m = ($all_ws | where name == $name)
    if ($m | is-empty) { null } else { $m | first }
}

# Resolve the requested workspace scope to a list of names.
# Empty list means "all workspaces" (default behavior).
# Errors on mutually exclusive flags.
def resolve-target-ws [workspace: string, current: bool] {
    if ($workspace | is-not-empty) and $current {
        error make { msg: "Pass only one of --workspace or --current" }
    }
    if ($workspace | is-not-empty) { return [$workspace] }
    if $current {
        let r = (do { ipc "-t get_workspaces" } | complete)
        if $r.exit_code != 0 or ($r.stdout | str trim | is-empty) {
            error make { msg: "Could not query focused workspace" }
        }
        let focused = ($r.stdout | from json | where focused == true)
        if ($focused | is-empty) {
            error make { msg: "No focused workspace found" }
        }
        return [($focused | first | get name)]
    }
    []
}

# List current workspaces with layout tree + state entries.
def "main list" [
    --output (-o): string    # Output format: "table" for flat rows, default is yaml tree
    --workspace: string = "" # Only this workspace
    --current                # Only the focused workspace
] {
    let targets = (resolve-target-ws $workspace $current)
    let workspaces_all = get-wm-workspaces
    let workspaces_raw = if ($targets | is-empty) {
        $workspaces_all
    } else {
        $workspaces_all | where workspace in $targets
    }

    if ($workspaces_raw | is-empty) {
        print "No workspaces with windows"
        return
    }

    let clients_result = (do { tmux list-clients -F "#{client_pid} #{session_name} #{window_index}" } | complete)
    let local_clients = if $clients_result.exit_code == 0 {
        $clients_result.stdout | lines | where $it != "" | each { |line|
            let parts = ($line | split row " ")
            { pid: ($parts.0 | into int), session: $parts.1, window: ($parts.2 | into int) }
        }
    } else { [] }

    let thin_result = (do { tmux -L thin list-clients -F "#{client_pid} #{session_name}" } | complete)
    let thin_clients = if $thin_result.exit_code == 0 {
        $thin_result.stdout | lines | where $it != "" | each { |line|
            let parts = ($line | split row " ")
            { pid: ($parts.0 | into int), session: $parts.1 }
        }
    } else { [] }

    let tmux_cache = (build-tmux-window-cache $local_clients $thin_clients)

    let workspaces = ($workspaces_raw | each { |ws|
        let enriched = ($ws.state | transpose k v
            | each { |it| { k: $it.k, v: (enrich-state-entry $it.v $local_clients $thin_clients $tmux_cache) } }
            | reduce -f {} { |it, acc| $acc | upsert $it.k $it.v })
        { name: $ws.workspace, layout: $ws.layout, state: $enriched }
    })

    if $output == "table" {
        $workspaces | each { |ws|
            $ws.state | transpose id entry | each { |it|
                { workspace: $ws.name, id: $it.id } | merge $it.entry
            }
        } | flatten | table
    } else {
        { workspaces: $workspaces } | to yaml
    }
}

# Query tmux for the active window_id of a session on a given server.
# server_type: "local" (default tmux socket) or "thin" (-L thin socket).
# Returns numeric string with leading '@' stripped, or "" on any failure.
# NOTE: Same session attached by two terminals will yield the same window_id
# for both saved entries — restore-side swallow regex will fire ambiguously.
# Documented as a known limitation in the script header.
def query-tmux-window-id [server_type: string, session: string] {
    if ($session | is-empty) { return "" }
    let r = if $server_type == "thin" {
        do { ^tmux -L thin display-message -t $"($session):" -p '#{window_id}' } | complete
    } else {
        do { ^tmux display-message -t $"($session):" -p '#{window_id}' } | complete
    }
    if $r.exit_code != 0 {
        print -e $"warn: tmux query failed for ($server_type):($session): ($r.stderr | str trim)"
        return ""
    }
    let raw = ($r.stdout | str trim)
    if ($raw | is-empty) {
        print -e $"warn: tmux query returned empty for ($server_type):($session)"
        return ""
    }
    # Strip leading '@' from window_id (tmux always prefixes with @).
    if ($raw | str starts-with "@") {
        $raw | str substring 1..
    } else {
        $raw
    }
}

# Build a per-save cache of (server_type, session) -> window_id by querying tmux
# once per unique pair from the merged client lists. Failures log to stderr and
# are absent from the cache (caller treats absence as "omit field").
def build-tmux-window-cache [local_clients: list<record>, thin_clients: list<record>] {
    mut cache = {}
    for c in $local_clients {
        let key = $"local:($c.session)"
        if not ($key in ($cache | columns)) {
            let wid = (query-tmux-window-id "local" $c.session)
            if ($wid | is-not-empty) {
                $cache = ($cache | upsert $key $wid)
            }
        }
    }
    for c in $thin_clients {
        let key = $"thin:($c.session)"
        if not ($key in ($cache | columns)) {
            let wid = (query-tmux-window-id "thin" $c.session)
            if ($wid | is-not-empty) {
                $cache = ($cache | upsert $key $wid)
            }
        }
    }
    $cache
}

# Enrich a state entry with tmux session info if its pid descends from a tmux client.
# Adds:
#   - session_type + session  (existing behavior, only if a tmux client matches)
#   - tmux_window_id          (when entry is a recognized terminal AND a session
#                              is attached AND the cache has a value for it)
#   - skip_restore: true      (when entry's class is NOT in terminal_ids — these
#                              are GUI apps tracked but not respawned by restore)
# Failures to query tmux degrade gracefully: omit tmux_window_id, never abort.
def enrich-state-entry [entry: record, local_clients: list<record>, thin_clients: list<record>, tmux_cache: record] {
    let cls = ($entry | get -o class | default "")
    let is_terminal = ($terminal_ids | any {|t| $t == $cls })

    # Non-terminal entries: tag skip_restore: true and short-circuit before any
    # tmux query work. Preserve all existing fields (wid/pid/class/title).
    if not $is_terminal {
        return ($entry | upsert skip_restore true)
    }

    # Terminal entry: existing session-discovery logic.
    let pid = ($entry | get -o pid | default 0)
    if $pid <= 0 { return $entry }

    mut found = $entry
    mut server_type = ""
    mut session = ""
    for c in $local_clients {
        if (is-descendant $pid $c.pid) {
            $found = ($entry | upsert session_type "local" | upsert session $c.session)
            $server_type = "local"
            $session = $c.session
            break
        }
    }
    if ($server_type | is-empty) {
        for c in $thin_clients {
            if (is-descendant $pid $c.pid) {
                $found = ($entry | upsert session_type "thin" | upsert session $c.session)
                $server_type = "thin"
                $session = $c.session
                break
            }
        }
    }

    # No tmux client owns this terminal -> return enriched-or-unchanged entry; no
    # tmux_window_id (terminal isn't running tmux).
    if ($server_type | is-empty) or ($session | is-empty) { return $found }

    # Look up cached window_id; absence (failed query at cache build time) means
    # we skip the field. Saved value is digits only (already stripped of '@').
    let cache_key = $"($server_type):($session)"
    let wid = ($tmux_cache | get -o $cache_key | default "")
    if ($wid | is-empty) { return $found }
    $found | upsert tmux_window_id $wid
}

# Save current WM state (layout tree + state list) to cache.
# Without flags: capture all workspaces, overwrite cache.
# With --workspace <name> or --current: merge that single workspace into existing cache.
def "main save" [
    --workspace: string = ""  # Save only this workspace, merge into cache
    --current                 # Save only the focused workspace, merge into cache
] {
    let targets = (resolve-target-ws $workspace $current)
    let workspaces_raw = get-wm-workspaces

    let clients_result = (do { tmux list-clients -F "#{client_pid} #{session_name} #{window_index}" } | complete)
    let local_clients = if $clients_result.exit_code == 0 {
        $clients_result.stdout | lines | where $it != "" | each { |line|
            let parts = ($line | split row " ")
            { pid: ($parts.0 | into int), session: $parts.1, window: ($parts.2 | into int) }
        }
    } else { [] }

    let thin_result = (do { tmux -L thin list-clients -F "#{client_pid} #{session_name}" } | complete)
    let thin_clients = if $thin_result.exit_code == 0 {
        $thin_result.stdout | lines | where $it != "" | each { |line|
            let parts = ($line | split row " ")
            { pid: ($parts.0 | into int), session: $parts.1 }
        }
    } else { [] }

    let tmux_cache = (build-tmux-window-cache $local_clients $thin_clients)

    let fresh = ($workspaces_raw | each { |ws|
        # state is a record keyed by id; enrich each value
        let enriched = ($ws.state | transpose k v
            | each { |it| { k: $it.k, v: (enrich-state-entry $it.v $local_clients $thin_clients $tmux_cache) } }
            | reduce -f {} { |it, acc| $acc | upsert $it.k $it.v })
        { name: $ws.workspace, layout: $ws.layout, state: $enriched }
    })

    let cache_path = ("~/.cache/sway-state.yaml" | path expand)

    if ($targets | is-empty) {
        # Default: overwrite cache with all captured workspaces.
        { workspaces: $fresh } | to yaml | save -f $cache_path
        print $"Saved ($fresh | length) workspaces"
        return
    }

    # Merge into existing cache.
    let existing = if ($cache_path | path exists) {
        (open $cache_path | get -o workspaces | default [])
    } else { [] }

    let target_name = ($targets | first)
    let target_matches = ($fresh | where name == $target_name)
    let target_new = if ($target_matches | is-empty) { null } else { $target_matches | first }

    if $target_new == null {
        # Target currently has no windows → remove from cache if present.
        let before_len = ($existing | length)
        let remaining = ($existing | where name != $target_name)
        { workspaces: $remaining } | to yaml | save -f $cache_path
        if ($before_len != ($remaining | length)) {
            print $"Removed empty workspace ($target_name) from cache"
        } else {
            print $"Workspace ($target_name) empty; nothing to save"
        }
        return
    }

    # Replace in place if present, else append.
    let has_existing = (not ($existing | where name == $target_name | is-empty))
    let merged = if $has_existing {
        $existing | each { |w| if $w.name == $target_name { $target_new } else { $w } }
    } else {
        $existing | append $target_new
    }
    { workspaces: $merged } | to yaml | save -f $cache_path
    print $"Saved workspace ($target_name)"
}

# Open saved state file in $EDITOR
def "main edit" [] {
    let state_file = ("~/.cache/sway-state.yaml" | path expand)
    if not ($state_file | path exists) {
        print "No saved state found"
        return
    }
    ^($env.EDITOR) $state_file
}

# Pre-clean a target workspace before a restore run.
#
# Strategy:
#   1. If <name> is absent → no-op (rc 0, no IPC).
#   2. If <name>-old already exists (leftover from a prior restore):
#        a. Kill every terminal in <name>-old (scoped by [id=<wid>] kill — never by class
#           alone, which would clobber terminals on other workspaces).
#        b. Rename the leftover <name>-old → <name>-old-<unix_ts> so the next rename
#           step (3) can land without a name collision. Non-terminal windows ride
#           along into the timestamped name and stay there for the user.
#   3. Rename <name> → <name>-old via [workspace=<name>] rename workspace to <name>-old.
#   4. Walk the renamed <name>-old tree (nodes + floating_nodes). For every leaf whose
#      class/app_id is in terminal_ids, issue [id=<wid>] kill. WM auto-deletes the
#      workspace if it ends up empty.
#
# --dry-run prints every IPC call and skips execution.
def isolate-target [name: string, --dry-run] {
    # Phase 1 of the two-phase restore cleanup. Rename target ws -> <name>-old
    # so the old terminals (and their tmux clients) stay ALIVE on <name>-old
    # while restore spawns new terminals on a fresh <name>. Killing the old
    # terminals here would detach their tmux clients; with destroy-unattached
    # on plus the tmux-cleanup hook, this destroys the tmux sessions and the
    # subsequent `tmux attach -t <session>` from the new terminals fails.
    # Phase 2 (`kill-old-terminals`) runs at the end of restore once the new
    # clients are attached.
    let tree_json = (do { ipc "-t get_tree" } | complete)
    if $tree_json.exit_code != 0 {
        print -e $"warn: get_tree failed for isolate-target ($name)"
        return
    }
    let tree = ($tree_json.stdout | from json)
    let target = (find-workspace-by-name $tree $name)
    if $target == null { return }

    let old_name = $"($name)-old"

    # Handle <name>-old collision before the rename step. Any terminals already
    # on <name>-old are leftovers from a PRIOR restore — their tmux clients are
    # not part of this restore's recovery set, so killing them is fine. (If we
    # left them attached, multiple stale clients would pile up and the user's
    # -old workspace would grow without bound across restores.)
    let leftover = (find-workspace-by-name $tree $old_name)
    if $leftover != null {
        let leftover_leaves = (collect-ws-windows $leftover "")
        for leaf in $leftover_leaves {
            let is_terminal = ($terminal_ids | any {|t| $t == $leaf.class })
            if not $is_terminal { continue }
            let cmd = $"[id=($leaf.wid)] kill"
            if $dry_run {
                print $"  DRY: ipc-raw ($cmd)"
            } else {
                ipc-raw $cmd
            }
        }
        let ts = (date now | format date "%s")
        let stamped = $"($old_name)-($ts)"
        # Use the canonical `rename workspace OLD to NEW` form. The criteria
        # variant `[workspace=OLD] rename workspace to NEW` behaves
        # inconsistently in i3 — it can rename the focused workspace instead.
        let rename_cmd = $"rename workspace ($old_name) to ($stamped)"
        if $dry_run {
            print $"  DRY: ipc-raw ($rename_cmd)"
        } else {
            ipc-raw $rename_cmd
        }
    }

    # Rename target ws -> <name>-old. WM rename preserves output binding.
    # No kill here: terminals stay alive on <name>-old so their tmux sessions
    # remain attached for the new respawn flow to reuse.
    let rename_target = $"rename workspace ($name) to ($old_name)"
    if $dry_run {
        print $"  DRY: ipc-raw ($rename_target)"
    } else {
        ipc-raw $rename_target
    }
}

# Find a live window matching a saved GUI leaf. wid-only match: saved_wid
# alive in the tree (same i3 session) AND its class still matches saved.
# Returns wid or 0 if no match.
#
# After logout/login all wids are fresh and this always returns 0 — that's by
# design. GUI windows can't be relaunched cleanly from a wm-state save
# (killing them kills application state); after a fresh login the user
# relaunches their GUI apps manually and the class swallow on the placeholder
# con consumes them into the saved slot when they map.
def find-live-gui-wid [tree: record, saved: record] {
    let saved_cls = ($saved | get -o class | default "")
    let saved_wid = ($saved | get -o saved_wid | default 0)
    if $saved_wid <= 0 or ($saved_cls | is-empty) { return 0 }
    let all_leaves = (find-workspaces $tree | each {|w| collect-ws-windows $w "" } | flatten)
    let m = ($all_leaves | where wid == $saved_wid)
    if ($m | is-empty) { return 0 }
    let pick = ($m | first)
    if $pick.class != $saved_cls { return 0 }
    $saved_wid
}

# Kill any stale wm-gui-* mark anchors left from a prior failed restore.
# Run before append_layout to keep the mark namespace clean.
def kill-stale-gui-marks [--dry-run] {
    let r = (do { ipc "-t get_marks" } | complete)
    if $r.exit_code != 0 { return }
    let marks = (try { $r.stdout | from json } catch { [] })
    let stale = ($marks | where { |m| $m | str starts-with "wm-gui-" })
    for m in $stale {
        let cmd = $"[con_mark=($m)] kill"
        if $dry_run {
            print $"  DRY: ipc-raw ($cmd)"
        } else {
            try { ipc-raw $cmd }
        }
    }
}

# Place a single GUI leaf: find live wid by saved class+title (or saved wid),
# move it to the placeholder mark, then kill the placeholder. If no live match,
# leave the placeholder in place — the class swallow will catch a fresh launch.
def place-gui-leaf [spec: record, --dry-run] {
    let mark = ($spec | get -o mark | default "")
    if ($mark | is-empty) { return }

    let tree_json = (do { ipc "-t get_tree" } | complete)
    if $tree_json.exit_code != 0 { return }
    let tree = ($tree_json.stdout | from json)

    let live_wid = (find-live-gui-wid $tree $spec)
    if $live_wid <= 0 {
        if $dry_run {
            print $"  DRY: GUI ($spec.class) no live match — placeholder kept for class swallow"
        }
        return
    }

    let move_cmd = $"[id=($live_wid)] floating disable, move container to mark ($mark)"
    let kill_cmd = $"[con_mark=($mark)] kill"
    if $dry_run {
        print $"  DRY: ipc-raw ($move_cmd)"
        print $"  DRY: ipc-raw ($kill_cmd)"
    } else {
        ipc-raw $move_cmd
        sleep 50ms
        try { ipc-raw $kill_cmd }
    }
}

def kill-old-terminals [old_name: string, --dry-run] {
    # Phase 2 of the two-phase restore cleanup. Walk <name>-old's leaves and
    # kill every terminal by wid. Run AFTER the new respawn flow has spawned
    # its terminals and they have attached to the saved tmux sessions, so each
    # session has the new client and destroy-unattached does not fire.
    # Non-terminals on <name>-old remain in place for the user to inspect.
    let tree_json = (do { ipc "-t get_tree" } | complete)
    if $tree_json.exit_code != 0 {
        print -e $"warn: get_tree failed for kill-old-terminals ($old_name)"
        return
    }
    let tree = ($tree_json.stdout | from json)
    let target = (find-workspace-by-name $tree $old_name)
    if $target == null { return }
    let leaves = (collect-ws-windows $target "")
    for leaf in $leaves {
        let is_terminal = ($terminal_ids | any {|t| $t == $leaf.class })
        if not $is_terminal { continue }
        let cmd = $"[id=($leaf.wid)] kill"
        if $dry_run {
            print $"  DRY: ipc-raw ($cmd)"
        } else {
            ipc-raw $cmd
        }
    }
}

# CLI wrappers so the two-phase cleanup primitives are callable directly.
def "main isolate-target" [
    name: string             # Target workspace name to isolate (rename only)
    --dry-run                # Print IPC calls without executing
] {
    isolate-target $name --dry-run=$dry_run
}

def "main kill-old-terminals" [
    old_name: string         # The <name>-old workspace whose terminals to kill
    --dry-run                # Print IPC calls without executing
] {
    kill-old-terminals $old_name --dry-run=$dry_run
}

def "main restore" [
    --dry-run                # Print actions without executing IPC commands
    --workspace: string = "" # Restore only this workspace from cache
    --current                # Restore only the focused workspace from cache
] {
    # Precondition: tmux server must be reachable. The respawn flow relies on
    # `tmux attach -t <session>` per terminal, so a dead server makes restore
    # meaningless. Abort hard rather than continue in a degraded mode.
    let tmux_check = (do { tmux list-sessions } | complete)
    if $tmux_check.exit_code != 0 {
        print -e "tmux server unreachable, aborting restore"
        exit 1
    }

    let targets = (resolve-target-ws $workspace $current)
    let state_file = ("~/.cache/sway-state.yaml" | path expand)
    if not ($state_file | path exists) {
        print "No saved state found"
        return
    }

    let state = (open $state_file)
    let all_workspaces = ($state | get -o workspaces | default [])
    let workspaces = if ($targets | is-empty) {
        $all_workspaces
    } else {
        $all_workspaces | where name in $targets
    }

    if ($workspaces | is-empty) {
        if ($targets | is-empty) {
            print "No workspaces to restore"
        } else {
            print $"No matching workspace in cache: ($targets | str join ',')"
        }
        return
    }

    let wm = (wm-name)
    if $wm == null {
        print -e "No supported WM detected"
        exit 1
    }
    let term = ($default_term_by_wm | get -o $wm | default "kitty")

    # Remember the workspace the user is currently on so we can return at the end.
    let start_ws = (do {
        let r = (do { ipc "-t get_workspaces" } | complete)
        if $r.exit_code != 0 { null } else {
            let f = ($r.stdout | from json | where focused == true)
            if ($f | is-empty) { null } else { $f | first | get name }
        }
    })

    # Two-phase cleanup:
    #   Phase 1 (this loop): isolate-target renames each ws -> <name>-old.
    #                        Old terminals stay alive on <name>-old, tmux
    #                        clients stay attached, sessions stay alive.
    #   Phase 2 (after spawn): kill-old-terminals walks <name>-old and kills
    #                        terminals only after the new respawn flow has
    #                        attached new clients to the saved tmux sessions.
    #   Phase 3 (after kill): for each respawned ws, place GUI leaves by
    #                        moving their live wid into the placeholder mark.
    #
    # Track which ws had a real respawn so phase 2/3 only touches those.
    mut respawned_ws = []
    mut gui_specs_by_ws = {}

    # Drop any stale wm-gui-* anchors left from a prior failed restore so
    # this run's marks have a clean slate.
    kill-stale-gui-marks --dry-run=$dry_run

    for ws in $workspaces {
        let ws_name = ($ws | get -o name | default "")
        if ($ws_name | is-empty) { continue }

        let layout_tree = ($ws | get -o layout | default null)
        let ws_state = ($ws | get -o state | default {})

        print $"Restoring workspace: ($ws_name)"

        if $layout_tree == null or (($ws_state | columns) | is-empty) {
            continue
        }

        # Phase 1: rename target -> <name>-old. NO kill. Old terminals + their
        # tmux clients survive while we reattach new clients to the same
        # sessions on the fresh <name>.
        isolate-target $ws_name --dry-run=$dry_run

        # Focus the (now empty) target workspace before append_layout.
        let focus_cmd = $"workspace --no-auto-back-and-forth ($ws_name)"
        if $dry_run {
            print $"  DRY: ipc-raw ($focus_cmd)"
        } else {
            ipc-raw $focus_cmd
        }

        # Build the respawn plan (append_layout JSON + spawn specs).
        let plan = (build-respawn-plan $layout_tree $ws_state $term $wm $ws_name)

        let json_nodes = ($plan.json | get -o nodes | default [])
        let non_skipped = ($plan.leaf_specs | where { |s| ($s | get -o skipped | default false) == false })
        let term_specs = ($non_skipped | where { |s| ($s | get -o swallow_kind | default "") != "gui" })
        let gui_specs = ($non_skipped | where { |s| ($s | get -o swallow_kind | default "") == "gui" })

        # If every leaf is skip_restore, leave the empty workspace alone and
        # do NOT schedule phase 2 — there's no new client to take over the old
        # terminals, so leaving them where they are is correct.
        if ($json_nodes | is-empty) and ($non_skipped | is-empty) {
            print $"  Workspace ($ws_name): skipped — all entries non-terminal"
            continue
        }

        # Write append_layout JSON + apply.
        if not ($json_nodes | is-empty) {
            let tmpfile = $"/tmp/wm-restore-($ws_name).json"
            let append_cmd = $"append_layout ($tmpfile)"
            if $dry_run {
                print $"  DRY: write ($tmpfile)"
                print $"  DRY: ipc-raw ($append_cmd)"
            } else {
                $plan.json | to json -r | save -f $tmpfile
                ipc-raw $append_cmd
                # Cushion only — correctness comes from the WM swallow firing on
                # window map. 80ms gives append_layout time to publish the
                # placeholder cons before we start spawning their occupants.
                sleep 80ms
            }
        }

        # Spawn each terminal leaf. Title swallow (carrying the tmux
        # window_id) routes the new window into the correct slot. No mark moves,
        # no parking, no inter-spawn sleeps — terminals spawn in parallel.
        for spec in $term_specs {
            let exec_cmd = ($spec | get -o exec_cmd | default "")
            if ($exec_cmd | is-empty) { continue }
            let cmd = $"exec ($exec_cmd)"
            if $dry_run {
                print $"  DRY: ipc-raw ($cmd)"
            } else {
                ipc-raw $cmd
            }
        }

        # Stash GUI specs for phase 3 (after kill-old-terminals).
        if not ($gui_specs | is-empty) {
            $gui_specs_by_ws = ($gui_specs_by_ws | upsert $ws_name $gui_specs)
        }
        $respawned_ws = ($respawned_ws | append $ws_name)
    }

    # Phase 2: wait for new terminals to map + tmux-attach, then kill old
    # terminals on each -old workspace. The new clients now hold those
    # sessions open, so destroy-unattached + tmux-cleanup will not destroy
    # them when the old clients detach.
    if not ($respawned_ws | is-empty) {
        if $dry_run {
            print "  DRY: sleep 600ms (let new terminals attach)"
        } else {
            sleep 600ms
        }
        for ws_name in $respawned_ws {
            kill-old-terminals $"($ws_name)-old" --dry-run=$dry_run
        }
    }

    # Phase 3: place GUI leaves into their marked placeholders. Run AFTER
    # kill-old-terminals so the layout is settled. For each GUI leaf, find
    # the live window (by saved wid first, then class+title heuristic) and
    # move it to the placeholder mark; then kill the placeholder. Live
    # windows that don't match any saved entry are left alone; placeholders
    # without a live match stay in place — their class swallow will catch
    # the app if the user later (re)launches it.
    let ws_with_gui = ($gui_specs_by_ws | columns)
    if not ($ws_with_gui | is-empty) {
        for ws_name in $ws_with_gui {
            let specs = ($gui_specs_by_ws | get $ws_name)
            for spec in $specs {
                place-gui-leaf $spec --dry-run=$dry_run
            }
        }
    }

    # Return user to their starting workspace (headless finish).
    if ($start_ws | is-not-empty) {
        let return_cmd = $"workspace --no-auto-back-and-forth ($start_ws)"
        if $dry_run {
            print $"  DRY: ipc-raw ($return_cmd)"
        } else {
            ipc-raw $return_cmd
        }
    }

    if $dry_run { print "Dry run complete" } else { print "Restore complete" }
}

# Unique per-slot identifier derived from leaf id (for class/app_id swallow).
def slot-id-for [id: string] {
    $"wm-slot-($id)"
}

# Is the given key a leaf id (numeric string)?
def is-leaf-key [k: string] {
    try { $k | into int; true } catch { false }
}

# Terminal class/app_id flag tokens (separate flag + value so they survive quoting).
def term-class-flag [term: string, slot_id: string] {
    if $term in ["kitty", "alacritty", "Alacritty"] {
        $"--class ($slot_id)"
    } else if $term == "foot" {
        $"--app-id ($slot_id)"
    } else if $term == "xterm" {
        $"-class ($slot_id)"
    } else {
        ""
    }
}

# Recursive helper for build-respawn-plan. Produces { nodes, leaf_specs } for the
# given container body. ws_name parameterises the per-ws mark prefix used by
# GUI placeholders (`wm-gui-<ws>-<id>`).
def build-respawn-container [body: record, state: record, term: string, wm: string, ws_name: string] {
    mut nodes = []
    mut leaf_specs = []
    let keys = ($body | columns)
    for key in $keys {
        let val = ($body | get $key)
        if (is-leaf-key $key) {
            let entry = ($state | get -o $key | default {})
            let cls = ($entry | get -o class | default "")
            let skip = ($entry | get -o skip_restore | default false)
            let wid = ($entry | get -o tmux_window_id | default "")
            let session = ($entry | get -o session | default "")
            let saved_wid = ($entry | get -o wid | default 0)
            let title = ($entry | get -o title | default "")
            let is_term = ($terminal_ids | any {|t| $t == $cls })

            if $is_term and ($wid | is-not-empty) and ($session | is-not-empty) {
                # Happy path: tmux-attached terminal. Match by title which
                # carries the tmux window_id at the end (set by tmux-start).
                # window_id is always digits (we strip the leading '@' at save
                # time) so no regex escaping is required for $wid here — the
                # only regex metacharacters in the pattern come from the literal
                # `.*` and `$` we add ourselves.
                $nodes = ($nodes | append { swallows: [{ title: $".* ($wid)$" }], type: "con" })
                $leaf_specs = ($leaf_specs | append {
                    id: $key,
                    swallow_kind: "title",
                    exec_cmd: $"($term) -e tmux attach -t ($session)",
                })
            } else if $is_term {
                # Best-effort fallback: terminal entry without a usable
                # tmux_window_id (legacy save, tmux query failed at save time,
                # or saved title was empty). Class swallow is shared across all
                # instances of the same terminal — placement is non-deterministic
                # if multiple new terminals appear concurrently.
                $nodes = ($nodes | append { swallows: [{ class: $"^($cls)$" }], type: "con" })
                $leaf_specs = ($leaf_specs | append {
                    id: $key,
                    swallow_kind: "class",
                    exec_cmd: $term,
                })
            } else if ($cls | is-not-empty) {
                # GUI leaf (skip_restore or non-terminal). Emit placeholder con
                # with a wm-gui-* mark + class swallow:
                #   - mark is the move-target for placing an EXISTING GUI
                #     window into this slot via `[id=<wid>] move container to
                #     mark <mark>` after append_layout publishes placeholders.
                #   - class swallow is the belt-and-suspenders fallback: if a
                #     fresh window of this class maps later, it consumes the
                #     placeholder.
                # The `wm-gui-` prefix is reserved so user marks never collide.
                let mark = $"wm-gui-($ws_name)-($key)"
                $nodes = ($nodes | append {
                    swallows: [{ class: $"^($cls)$" }],
                    marks: [$mark],
                    type: "con",
                })
                $leaf_specs = ($leaf_specs | append {
                    id: $key,
                    swallow_kind: "gui",
                    mark: $mark,
                    class: $cls,
                    title: $title,
                    saved_wid: $saved_wid,
                })
            } else {
                # No class info at all (corrupt entry). Record skipped, no JSON node.
                $leaf_specs = ($leaf_specs | append { id: $key, skipped: true })
            }
        } else {
            # Container key. Strip uniqueness suffix (-2, -3, ...) before emit.
            let layout_type = ($key | split row "-" | first)
            let sub = (build-respawn-container $val $state $term $wm $ws_name)
            $leaf_specs = ($leaf_specs | append $sub.leaf_specs)
            # Empty container body -> omit the entire container so we don't
            # append an empty con (which would render as a stray empty pane).
            if (($sub.nodes | length) > 0) {
                $nodes = ($nodes | append {
                    layout: $layout_type,
                    type: "con",
                    nodes: $sub.nodes,
                })
            }
        }
    }
    { nodes: $nodes, leaf_specs: $leaf_specs }
}

# Build append_layout JSON + spawn specs for a workspace layout tree.
# Returns: { json: <append_layout-record>, leaf_specs: [...] }
#   json       — feed to append_layout via tmpfile. Top-level shape:
#                  { layout: <root_type>, type: "con", nodes: [...] }
#                Empty `nodes` means "every leaf was skip_restore"; caller
#                should elide the append_layout call entirely.
#   leaf_specs — list of `{ id, swallow_kind, exec_cmd, skipped? }`. Skipped
#                entries have only `{ id, skipped: true }`; non-skipped entries
#                carry the exec_cmd to issue (`<term> -e tmux attach -t <ses>`
#                for the title path, bare `<term>` for the class fallback).
#
# Drives the new respawn flow: append_layout publishes placeholders with title
# or class swallows; spawn loop issues `exec` commands and the WM swallow fires
# on map. No live-window matching or move-by-mark involved.
def build-respawn-plan [layout_tree: record, state: record, term: string, wm: string, ws_name: string] {
    let root_key = ($layout_tree | columns | first)
    let root_body = ($layout_tree | get $root_key)
    let root_type = ($root_key | split row "-" | first)
    let res = (build-respawn-container $root_body $state $term $wm $ws_name)
    # type:"con" at root: append_layout adds the con as a child of the
    # currently-focused workspace (caller focuses the target ws first via
    # `workspace --no-auto-back-and-forth <ws_name>`). type:"workspace"
    # creates an unnamed *new* workspace instead of merging — avoid it.
    {
        json: { type: "con", layout: $root_type, nodes: $res.nodes },
        leaf_specs: $res.leaf_specs,
    }
}

# Compose a shell exec string to launch the given terminal with a slot id.
# extra_env: env vars prefix (e.g. "TMUX_TARGET=foo"). trailing: command inside term.
def build-term-spawn [term: string, slot_id: string, extra_env: string, trailing: string] {
    let class_flag = (term-class-flag $term $slot_id)
    let base = if $term == "kitty" {
        # kitty <flags> [cmd args...]
        if ($trailing | is-empty) { $"($term) ($class_flag)" } else { $"($term) ($class_flag) ($trailing)" }
    } else {
        # foot / alacritty / xterm: <term> <flags> [-e cmd]
        if ($trailing | is-empty) { $"($term) ($class_flag)" } else { $"($term) ($class_flag) -e ($trailing)" }
    }
    if ($extra_env | is-empty) { $base } else { $"env ($extra_env) ($base)" }
}

# Compose the exec command string for a single state entry on restore.
def spawn-for [entry: record, term: string, id: string] {
    let cls = ($entry | get -o class | default "")
    let session = ($entry | get -o session | default "")
    let session_type = ($entry | get -o session_type | default "")
    let is_term = ($terminal_ids | any {|t| $t == $cls })
    let slot = (slot-id-for $id)

    if $is_term {
        if $session_type == "thin" {
            let ssh_args = ($entry | get -o ssh_args | default "")
            let remote_session = ($entry | get -o remote_session | default "")
            if ($ssh_args | is-empty) or ($remote_session | is-empty) {
                return (build-term-spawn $term $slot "" "")
            }
            let inner = $"tmux-to-workstation connect -g ($remote_session) -- ($ssh_args)"
            return (build-term-spawn $term $slot "" $"nu -c '($inner)'")
        }
        if ($session | is-not-empty) {
            let target = (do { tmux-start start 0 $session } | complete | get stdout | str trim)
            return (build-term-spawn $term $slot $"TMUX_TARGET=($target)" "")
        }
        return (build-term-spawn $term $slot "" "")
    }

    # Non-terminal: exec by natural class as a best-effort launcher.
    if ($cls | is-not-empty) { $cls } else { "" }
}

def main [] {
    print "wm-state - workspace layout + tmux session capture / restore"
    print ""
    print "Commands:"
    print "  list [-o table] [--workspace <name>|--current]   List workspace layout + state"
    print "  save [--workspace <name>|--current]              Save to cache (merge when scoped)"
    print "  edit                                             Open state file in \$EDITOR"
    print "  restore [--dry-run] [--workspace <name>|--current]  Restore from saved state"
    print "  isolate-target <name> [--dry-run]                Rename <name>→<name>-old (no kill)"
    print "  kill-old-terminals <name>-old [--dry-run]        Kill terminals on <name>-old workspace"
}
