#!/usr/bin/env nu
# tmux-to-workstation: local thin, remote fat
# Connect to remote where the full tmux UI lives
# Symlinked to ~/.local/bin/tmux-to-workstation via rotz

# Extract hostname from SSH args (same pattern as tmux-ssh)
def parse-hostname [args: list<string>]: nothing -> string {
    $args
        | reduce --fold { skip: false, host: null } {|arg, acc|
            if $acc.skip {
                { skip: false, host: $acc.host }
            } else if ($arg | str starts-with "-") {
                let value_flags = ["-p" "-l" "-i" "-o" "-F" "-J" "-L" "-R" "-D" "-W" "-E" "-S" "-b" "-c" "-e" "-m" "-O" "-Q" "-w" "-B"]
                if ($arg in $value_flags) {
                    { skip: true, host: $acc.host }
                } else {
                    { skip: false, host: $acc.host }
                }
            } else if ($acc.host == null) {
                { skip: false, host: $arg }
            } else {
                $acc
            }
        }
        | get host
}

# Extract port value from ssh args
def get-port [args: list<string>]: nothing -> string {
    if ($args | any {|a| $a == "-p"}) {
        let port_idx = ($args | enumerate | where {|e| $e.item == "-p"} | first | get index)
        $args | get ($port_idx + 1)
    } else { "" }
}

# Create a new independent thin session with metadata
def create-thin-session [cmd: string, meta: record]: nothing -> string {
    let config_path = ($env.HOME | path join ".dotfiles/tmux/tmux-thin-local.conf")

    # Find next thin_N number
    let existing = try {
        tmux -L thin list-sessions -F '#{session_name}' | lines | where {|s| $s =~ '^thin_\d+$'} | each {|s| $s | str replace 'thin_' '' | into int}
    } catch { [] }
    let nr = if ($existing | is-empty) { 0 } else { ($existing | math max) + 1 }
    let session_name = $"thin_($nr)"

    # Create independent session (not linked)
    let pane_id = (tmux -L thin -f $config_path new-session -d -P -F '#{pane_id}' -s $session_name $cmd | str trim)

    # Store metadata
    $meta | items {|key, val| tmux -L thin set-option -p -t $pane_id $"@($key)" $val }

    $session_name
}

def --wrapped "main connect" [
    --group (-g): string  # Remote session group name (default: "local")
    ...args: string       # SSH args (e.g. -p 8022 user@host)
] {
    if ($args | is-empty) {
        main
        return
    }

    let hostname = parse-hostname $args

    if ($hostname == null) {
        print "Error: could not determine hostname from args"
        return
    }

    let display_host = if ($hostname | str contains "@") {
        $hostname | split row "@" | last
    } else {
        $hostname
    }

    let port = get-port $args

    # Pick group from current tmux session if not specified
    let remote_session = if ($group | is-not-empty) {
        $group
    } else if ($env | get -o TMUX | is-not-empty) {
        tmux display-message -p '#{session_group}' | str trim
    } else {
        "local"
    }

    # Thin window name encodes connection info
    let thin_window = $"($display_host)_($remote_session)"

    # Create linked session on remote via SSH (headless)
    let target = (^ssh ...$args $"~/.local/bin/tmux-start start 0 ($remote_session)" 2>/dev/null | str trim)
    if ($target | is-empty) {
        print $"Error: tmux-start failed on ($display_host)"
        return
    }

    # Resolve stable remote_target as session_group:window_id
    let remote_target = (^ssh ...$args $"tmux display-message -t '($target)' -p '#{session_group}:#{window_id}'" 2>/dev/null | str trim)
    let remote_target = if ($remote_target | is-empty) { $target } else { $remote_target }

    # SSH command for the thin pane
    let ssh_cmd = $"ssh -t ($args | str join ' ') TMUX_TARGET=($target) bash -li"

    let session_name = create-thin-session $ssh_cmd {
        remote_name: $display_host
        remote_host: $hostname
        remote_session: $remote_session
        remote_port: $port
        remote_target: $remote_target
        ssh_args: ($args | str join " ")
    }

    # Attach
    if ($env | get -o TMUX | is-not-empty) {
        tmux detach-client -E $"tmux -L thin attach-session -t ($session_name)"
    } else {
        tmux -L thin attach-session -t $session_name
    }
}

def "main list" [
    --output (-o): string  # Output format: "table" for tabular, default is yaml
    --check (-c)           # Check if remote connections are live via SSH ping
] {
    # List all thin sessions with metadata
    let panes = try {
        tmux -L thin list-panes -a -F '#{session_name}|#{pane_dead}|#{pane_pid}|#{@remote_name}|#{@remote_host}|#{@remote_session}|#{@remote_port}|#{@remote_target}|#{@ssh_args}' | lines
    } catch {
        print "No local thin tmux running"
        return
    }

    if ($panes | is-empty) {
        print "No thin sessions"
        return
    }

    # When --check, query each unique remote host once for all windows
    let remote_windows_map = if $check {
        let hosts = $panes | each {|l|
            let parts = ($l | split row "|")
            { host: ($parts | get 4), ssh_args: ($parts | get 8) }
        } | where { |h| $h.ssh_args | is-not-empty } | uniq-by host

        $hosts | each {|h|
            let ssh_parts = ($h.ssh_args | split row " ")
            let result = (do { ^ssh -o ConnectTimeout=3 -o BatchMode=yes ...$ssh_parts "tmux list-windows -a -F '#{session_group}:#{window_id}||#{pane_title} - #{pane_current_command}@#{session_group}'" } | complete)
            let windows = if $result.exit_code == 0 {
                $result.stdout | lines | where { |s| $s | is-not-empty }
                | each {|l|
                    let parts = ($l | split row "||")
                    let id_parts = ($parts | get 0 | split row ":")
                    { group: ($id_parts | get 0), window_id: ($id_parts | get 1), title: ($parts | get 1) }
                }
                | uniq-by window_id
            } else { [] }
            { host: $h.host, windows: $windows }
        }
    } else { [] }

    let sessions = $panes | each {|l|
        let parts = ($l | split row "|")
        let ssh_args = ($parts | get 8)
        let remote_host = ($parts | get 4)
        let remote_target = ($parts | get 7)
        let remote_session = ($parts | get 5)
        # Extract window_id from remote_target (e.g. "auctions_0:@5" -> "@5")
        let remote_wid = if ($remote_target | str contains ":@") {
            $remote_target | split row ":" | last
        } else { "" }
        let check_result = if $check and ($ssh_args | is-not-empty) {
            let host_entry = ($remote_windows_map | where host == $remote_host)
            if ($host_entry | is-not-empty) {
                let windows = ($host_entry | first | get windows)
                let group_live = ($windows | any {|w| $w.group == $remote_session })
                # Match by session_group + window_id
                let matched = if ($remote_wid | is-not-empty) {
                    let m = ($windows | where group == $remote_session and window_id == $remote_wid)
                    if ($m | is-not-empty) { $m | first } else { null }
                } else { null }
                {
                    remote_live: $group_live
                    remote_wid: (if $matched != null { $matched.window_id } else { null })
                    remote_window: (if $matched != null { $matched.title } else { null })
                }
            } else {
                { remote_live: false, remote_wid: null, remote_window: null }
            }
        } else {
            null
        }
        let base = {
            session: ($parts | get 0)
            status: (if ($parts | get 1) == "1" { "dead" } else { "connected" })
            pid: ($parts | get 2)
            remote_name: ($parts | get 3)
            remote_host: $remote_host
            remote_session: ($parts | get 5)
            remote_port: ($parts | get 6)
            remote_target: $remote_target
            ssh_args: $ssh_args
        }
        if $check and $check_result != null {
            $base | merge $check_result
        } else { $base }
    }

    if $output == "table" {
        $sessions | table
    } else {
        $sessions | to yaml
    }
}

def "main reconnect" [
    --all (-a)  # Reconnect all dead sessions (skip picker)
] {
    # Check thin tmux is running
    let thin_running = (do { tmux -L thin list-sessions } | complete | get exit_code) == 0

    if not $thin_running {
        print "No local thin tmux running"
        return
    }

    # List dead thin sessions with metadata
    let dead = try {
        tmux -L thin list-panes -a -F '#{session_name}|#{pane_dead}|#{@ssh_args}|#{@remote_session}|#{pane_title}' | lines
        | where {|l| ($l | split row "|" | get 1) == "1" }
        | each {|l|
            let parts = ($l | split row "|")
            {
                session: ($parts | get 0)
                ssh_args: ($parts | get 2)
                remote_session: ($parts | get 3)
                title: ($parts | get 4)
            }
        }
        | where {|d| ($d.ssh_args | is-not-empty) and ($d.remote_session | is-not-empty) }
    } catch { [] }

    if ($dead | is-empty) {
        print "No dead thin sessions with metadata to reconnect"
        return
    }

    # Pick which to reconnect
    let selected = if $all {
        $dead
    } else {
        let items = $dead | each {|d| $"($d.session)\t($d.title) [($d.remote_session)]" }
        let picked = ($items | str join "\n" | fzf --multi --prompt "Reconnect (tab=select): " --with-nth=2.. | lines)
        if ($picked | is-empty) { return }
        $picked | each {|p|
            let session = ($p | split row "\t" | first)
            $dead | where {|d| $d.session == $session } | first
        }
    }

    for entry in $selected {
        let ssh_args = ($entry.ssh_args | split row " ")

        # Get fresh remote target
        let target = (^ssh ...$ssh_args $"~/.local/bin/tmux-start start 0 ($entry.remote_session)" 2>/dev/null | str trim)
        if ($target | is-empty) {
            print $"Error: tmux-start failed for ($entry.session) -> ($entry.remote_session)"
            continue
        }

        let ssh_cmd = $"ssh -t ($entry.ssh_args) TMUX_TARGET=($target) bash -li"

        # Respawn the dead pane
        tmux -L thin respawn-pane -k -t $"($entry.session):0.0" $ssh_cmd

        # Update metadata
        tmux -L thin set-option -p -t $"($entry.session):0.0" @remote_target $target

        print $"Reconnected: ($entry.session) -> ($entry.remote_session) [($target)]"
    }
}

def "main cleanup" [] {
    # Multi-select picker to kill local thin windows
    let windows = try {
        tmux -L thin list-windows -t thin -F '#{window_name}:#{window_id}:#{pane_dead}' | lines
    } catch {
        print "No local thin tmux running"
        return
    }

    if ($windows | is-empty) {
        print "No thin windows"
        return
    }

    # Build picker list with status
    let items = $windows | each {|w|
        let parts = ($w | split row ":")
        let name = ($parts | get 0)
        let id = ($parts | get 1)
        let status = if ($parts | get 2) == "1" { "(dead)" } else { "(connected)" }
        $"($id)\t($name) ($status)"
    }

    # fzf multi-select: tab to select, enter to confirm
    let selected = ($items | str join "\n" | fzf --multi --prompt "Kill windows (tab=select, enter=confirm): " --with-nth=2.. | lines)

    if ($selected | is-empty) {
        return
    }

    for line in $selected {
        let id = ($line | split row "\t" | first)
        let label = ($line | split row "\t" | last)
        tmux -L thin kill-window -t $id
        print $"Killed: ($label)"
    }
}

def main [] {
    print "tmux-to-workstation - local thin, remote fat"
    print ""
    print "Commands:"
    print "  connect [-g group] -- [ssh-args] <host>   Connect to remote fat session"
    print "  list                           List local thin windows"
    print "  reconnect [session]            Reattach to local thin tmux"
    print "  cleanup                        Kill dead thin windows"
}
