#!/usr/bin/env nu
# akm — manage markdown-oxide PKM workspaces (AKM zettelkasten) and the
# bd (beads) state plumbing that backs them.
#
# AKM subcommands (zettel + board lifecycle):
#   akm init <target>     bootstrap (or re-link) PKM under <target>/docs/
#   akm create <name>     mint sp### at status:idea + board.md ## idea entry
#   akm delete <name>     delete sp### + remove board.md entry
#   akm list              show all sp### grouped by status
#   akm root              print AKM workspace root (wraps the akm-root helper)
#
# bd housekeeping (`akm bd ...`):
#   akm bd init           strip bd auto-hooks, pin bd config (run once per repo)
#   akm bd export         bd Dolt → .beads/issues-snapshot.jsonl (commit-ready)
#   akm bd import         .beads/issues-snapshot.jsonl → bd Dolt (after a git pull)
#   akm bd archive create snapshot + prune old closed issues
#   akm bd archive apply  apply prune-list on other machines
#
# Examples:
#   akm init .                       # init current repo
#   akm create rotate-credentials    # mint sp025 (or next id) at status:idea
#   akm delete sp025                 # remove by id
#   akm list                         # idea / spec / ready / done buckets
#   akm bd init                      # bd hook strip + config pin
#   akm bd export                    # snapshot Dolt before commit
#
# Env overrides:
#   AKM_SOURCE          absolute path to canonical akm.md
#                       default: ~/.dotfiles/claude/akm/akm.md
#   AKM_ROOT_OVERRIDE   force a workspace path (testing / non-standard layouts)
#
# Design contract — bd epic / task LIFECYCLE is out of scope here:
#   `akm bd ...` is bd state PLUMBING only (hook strip, jsonl snapshot/restore,
#   archival pruning). Beads (bd) epic creation, task minting, and closure
#   happen in the lifecycle skills (`spec-ready` mints the bd epic and child
#   tasks when sp### → ready; `spec-retro` closes them when sp### → done).
#   Keeping lifecycle out of the CLI means the AKM data model stays coherent
#   regardless of which work-tracker the team uses.
#
# Workspace resolution — strict main-worktree rule:
#   Every AKM zettel operation (read, search, write) resolves its workspace
#   via the `akm-root` helper. From a feature worktree akm-root refuses with
#   exit 2 and stderr explaining where to `cd`. This CLI surfaces that
#   message verbatim. AKM zettels live on the default branch; feature
#   worktrees exist only for code work (work-do / work-audit / work-merge).
#   bd housekeeping commands (`akm bd ...`) use a separate `bd_project_root`
#   resolver — bd Dolt state is repo-scoped, not branch-scoped, so they work
#   from any worktree.

# Resolve the AKM workspace root via the `akm-root` shell helper.
#   exit 0 → return path (cwd is inside the main worktree of an AKM repo)
#   exit 1 → return ""   (no AKM workspace — non-AKM repo or no default branch)
#   exit 2 → raise       (strict refusal — cwd is on a feature worktree;
#                         caller surfaces the helper's stderr to the user)
def akm_root [] {
  let r = (do { ^akm-root } | complete)
  if $r.exit_code == 0 {
    $r.stdout | str trim
  } else if $r.exit_code == 2 {
    error make { msg: ($r.stderr | str trim) }
  } else {
    ""
  }
}

# Require an initialized AKM workspace and return its root.
# Errors with a hint when called from a non-AKM repo or before `akm init`.
def require_akm_root [] {
  let root = (akm_root)
  if ($root == "") {
    error make { msg: "no AKM workspace (no default branch detected) — run `akm init .` first" }
  }
  let docs = $"($root)/docs"
  if not ($docs | path exists) {
    error make { msg: $"AKM not initialized in ($root) — run `akm init ($root)` first" }
  }
  $root
}

# Glob sp###.md files under docs/notes/spec/ and return next zero-padded
# 3-digit id (e.g. "sp003"). Robust to gaps — picks max + 1, not count + 1.
def next_sp_id [root: string] {
  let dir = $"($root)/docs/notes/spec"
  if not ($dir | path exists) { mkdir $dir }
  let existing = (glob $"($dir)/sp*.md")
  let nums = ($existing | each { |f|
    ($f | path basename | str replace -r '^sp(\d+)\.md$' '$1' | into int)
  })
  let next = (if ($nums | is-empty) { 1 } else { ($nums | math max) + 1 })
  $"sp(($next) | fill -a r -c '0' -w 3)"
}

# Insert `- [[sp_id|name]]` under `## idea` of docs/board.md. Idempotent —
# skips if the wikilink already exists anywhere in the file. The board.md
# must already have `## idea` / `## spec` / `## ready` sections (created by
# `akm init`); a missing section is surfaced as a no-op with a warning so
# the user can fix the file before retrying.
def add_to_board_idea [board: string, sp_id: string, name: string] {
  let content = (open --raw $board)
  if ($content | str contains $"[[($sp_id)|") { return }
  let lines = ($content | lines)
  let idea_idx = ($lines | enumerate | where { |it| $it.item == "## idea" } | get -o 0.index)
  if ($idea_idx == null) {
    print -e $"warn: ($board) missing `## idea` section — sp### entry not inserted"
    return
  }
  let insert_at = ($idea_idx + 1)
  let link = $"- [[($sp_id)|($name)]]"
  let new_lines = (
    ($lines | take $insert_at)
    | append ""
    | append $link
    | append ($lines | skip $insert_at)
  )
  ($new_lines | str join "\n") | save -f $board
}

# Strip a single `[[sp_id|...]]` line from board.md. Leaves section
# structure intact so the file is reusable after delete.
def remove_from_board [board: string, sp_id: string] {
  if not ($board | path exists) { return }
  let pat = $"[[($sp_id)|"
  let kept = (open --raw $board | lines | where { |l| not ($l | str contains $pat) })
  ($kept | str join "\n") | save -f $board
}

# Parse YAML frontmatter (first --- ... --- block) into a list of "key: value" lines.
def frontmatter [content: string] {
  let lines = ($content | lines)
  if ($lines | is-empty) or ($lines | first) != "---" {
    return []
  }
  let rest = ($lines | skip 1)
  let end = ($rest | enumerate | where item == "---" | get -o 0.index)
  if ($end | is-empty) { return [] }
  $rest | take $end
}

# Read a top-level scalar field from frontmatter ("status: idea" → "idea").
# Returns "" when key absent. Aliases (a list) need separate parsing.
def read_field [content: string, key: string] {
  let fm = (frontmatter $content)
  let matches = ($fm | where { |l| $l | str starts-with $"($key):" })
  if ($matches | is-empty) {
    ""
  } else {
    $matches | first | str replace $"($key):" "" | str trim
  }
}

# Read the first alias entry from frontmatter:
#   aliases:
#     - foo
#     - bar
# Returns "foo" or "" when block absent. First alias is the canonical name
# the user passed to `akm create`.
def read_first_alias [content: string] {
  let lines = (frontmatter $content)
  let idx = ($lines | enumerate | where { |it| ($it.item | str trim) == "aliases:" } | get -o 0.index)
  if ($idx == null) { return "" }
  let after = ($lines | skip ($idx + 1))
  let first_item = ($after | first)
  if ($first_item == null) { return "" }
  let s = ($first_item | str trim)
  if ($s | str starts-with "- ") {
    $s | str replace -r '^- ' '' | str trim
  } else {
    ""
  }
}

# Find an sp###.md file by either its id ("sp025") or its first alias.
# Returns absolute path or "" when no match.
def find_sp_file [root: string, key: string] {
  let dir = $"($root)/docs/notes/spec"
  if not ($dir | path exists) { return "" }
  # By id — direct hit.
  if ($key =~ '^sp\d{3}$') {
    let f = $"($dir)/($key).md"
    if ($f | path exists) { return $f }
  }
  # By alias — scan all sp###.md frontmatter.
  let candidates = (glob $"($dir)/sp*.md")
  for f in $candidates {
    let content = (open --raw $f)
    let alias = (read_first_alias $content)
    if $alias == $key { return $f }
  }
  ""
}

def "main init" [target: string] {
  let akm_source = ($env.AKM_SOURCE? | default $"($env.HOME)/.dotfiles/claude/akm/akm.md")

  if not ($akm_source | path exists) {
    error make {
      msg: $"AKM source not found at ($akm_source). Create it first, or override via AKM_SOURCE env var."
    }
  }

  let root = ($target | path expand)
  let docs = $"($root)/docs"
  let notes = $"($docs)/notes"
  let daily = $"($notes)/daily"
  let assets = $"($docs)/assets"
  let spec_dir = $"($notes)/spec"

  mkdir $docs $notes $daily $assets $spec_dir

  # Placeholder gitkeeps (no-op if already exist).
  for d in [$notes $daily $assets $spec_dir] {
    let keep = $"($d)/.gitkeep"
    if not ($keep | path exists) { touch $keep }
  }

  # .moxide.toml — markdown-oxide workspace config.
  let moxide = $"($docs)/.moxide.toml"
  if not ($moxide | path exists) {
    let content = '# markdown-oxide PKM workspace config
# Workspace root: ./docs/
# Notes (zettel) live in ./docs/notes/
# Assets live in ./docs/assets/ (managed outside moxide — Obsidian attachmentFolderPath if used)

dailynote = "%Y-%m-%d"

new_file_folder_path = "notes"
daily_notes_folder = "notes/daily"

heading_completions = true
title_headings = true
unresolved_diagnostics = true
semantic_tokens = true

link_filenames_only = true

include_md_extension_md_link = false
include_md_extension_wikilink = false

case_matching = "Smart"

inlay_hints = true
block_transclusion = true
block_transclusion_length = "Full"

excluded_folders = ["assets"]
'
    $content | save --force $moxide
    print $"created: ($moxide)"
  } else {
    print $"kept:    ($moxide)"
  }

  # .markdownlint.json — lint relaxations.
  let lint = $"($docs)/.markdownlint.json"
  if not ($lint | path exists) {
    '{
  "MD022": false,
  "MD032": false
}
' | save --force $lint
    print $"created: ($lint)"
  } else {
    print $"kept:    ($lint)"
  }

  # product.md — hub stub if missing (don't overwrite existing).
  let product = $"($docs)/product.md"
  if not ($product | path exists) {
    let stub = '# Product

Central hub for this PKM. Every typed zettel is reachable from here.

## Stories

_(none yet — add `[[us###|<want clause>]]` under a persona heading)_

## Features

_(none yet — add `[[ft###|<capability>]]` entries when defined)_

## Architecture Decision Records

_(none yet — group `[[adr####]]` entries by `### [[cat###]]`)_

## AKM Reference

- [[akm]] — knowledge model: every zettel type, its schema and life-cycle
'
    $stub | save --force $product
    print $"created: ($product)"
  } else {
    print $"kept:    ($product)"
  }

  # board.md — spec lifecycle index. Sections match sp### status values.
  let board = $"($docs)/board.md"
  if not ($board | path exists) {
    let board_stub = '# Board

Active workstreams. Specs (`sp###`) at `status` ∈ {idea, spec, ready} grouped
under section headings matching their status. Move entries between sections
when status flips; `spec-retro` moves `done` entries into `archive.md`.

## idea

## spec

## ready
'
    $board_stub | save --force $board
    print $"created: ($board)"
  } else {
    # Existing board.md must have the three section headings or
    # `akm create` will silently no-op on board insertion.
    let content = (open --raw $board)
    let missing = (["## idea" "## spec" "## ready"]
      | where { |h| not ($content | str contains $h) })
    if not ($missing | is-empty) {
      print -e $"warn: ($board) missing sections: ($missing | str join ', ')"
      print -e "      `akm create` will not insert sp### links until these exist."
    } else {
      print $"kept:    ($board)"
    }
  }

  # akm.md — symlink to canonical source.
  # Use `test -L` so broken symlinks (target moved/renamed) get refreshed
  # instead of blocking the new `ln -s`.
  let akm_link = $"($notes)/akm.md"
  let is_symlink = ((^test -L $akm_link | complete | get exit_code) == 0)
  let is_regular = ((^test -e $akm_link | complete | get exit_code) == 0) and (not $is_symlink)

  if $is_symlink {
    ^rm $akm_link
  } else if $is_regular {
    print $"warn:    ($akm_link) exists as regular file; backing up to akm.md.bak"
    mv $akm_link $"($akm_link).bak"
  }
  ^ln -s $akm_source $akm_link
  print $"linked:  ($akm_link) -> ($akm_source)"

  print ""
  print $"PKM ready under ($docs)."
}

# Mint a new sp### zettel at status:idea, link it from docs/board.md.
# Frontmatter carries metadata that used to live in board/idea/*.md (alias
# name, claude_session_id when --session is passed) — sp### is the single
# canonical record for a workstream.
def "main create" [
  name: string
  --session  # also mint a claude session id for `claude --session-id <id>` resume
] {
  if not ($name =~ '^[a-zA-Z0-9_-]+$') {
    error make { msg: "name must contain only alphanumeric characters, dashes, and underscores" }
  }
  let root = (require_akm_root)

  # Refuse if an sp### already exists with this alias (idempotency boundary —
  # mint once; `akm create foo` twice is almost certainly a user mistake).
  let existing = (find_sp_file $root $name)
  if ($existing != "") {
    print -e $"already exists: ($existing)"
    return
  }

  let sp_id = (next_sp_id $root)
  let f = $"($root)/docs/notes/spec/($sp_id).md"
  let today = (date now | format date "%Y-%m-%d")

  let session_id = (if $session { (random uuid) } else { "" })

  let fm_base = [
    "---"
    "aliases:"
    $"  - ($name)"
    "status: idea"
    $"created: ($today)"
  ]
  let fm = (if ($session_id != "") {
    $fm_base | append $"claude_session_id: ($session_id)"
  } else { $fm_base })

  let body = ([
    "---"
    "# Spec [[board]]"
    ""
    "## problem"
    $"TBD — captured at idea-* skill stage for ($name)."
    ""
    "---"
    ""
    "Index: [[board]]"
    ""
  ])

  ($fm | append $body | str join "\n") | save -f $f
  print -e $"Created ($f)"

  # Insert link in docs/board.md ## idea section.
  let board = $"($root)/docs/board.md"
  if ($board | path exists) {
    add_to_board_idea $board $sp_id $name
    print -e $"Linked in ($board) ## idea"
  } else {
    print -e $"warn: ($board) missing — run `akm init ($root)` to scaffold"
  }

  if ($session_id != "") {
    print -e ""
    print -e $"Resume cmd: claude --session-id ($session_id) -n ($name).($sp_id)"
  }
}

# Delete sp### + its board.md entry. Accepts id ("sp025") or alias.
# Does NOT touch bd — the bd epic (if any) lives independently and is
# managed by the lifecycle skills.
def "main delete" [
  key: string
  --force  # skip confirmation
] {
  let root = (require_akm_root)
  let f = (find_sp_file $root $key)
  if ($f == "") {
    error make { msg: $"no sp### matching `($key)` (by id or alias)" }
  }
  let sp_id = ($f | path basename | str replace ".md" "")
  let board = $"($root)/docs/board.md"

  if not $force {
    print -e $"Will delete:"
    print -e $"  ($f)"
    if ($board | path exists) {
      print -e $"  ($board) entry for ($sp_id)"
    }
    let ans = (input "Proceed? [y/N]: ")
    if ($ans | str downcase) != "y" {
      print -e "Aborted"
      return
    }
  }

  rm $f
  remove_from_board $board $sp_id
  print -e $"Deleted ($sp_id)"
}

# List all sp### zettels grouped by status. Frontmatter is the source of
# truth for status — board.md sections are a navigational index, not state.
def "main list" [] {
  let root = (require_akm_root)
  let dir = $"($root)/docs/notes/spec"
  if not ($dir | path exists) {
    print "No sp### zettels (docs/notes/spec/ absent)"
    return
  }
  let files = (glob $"($dir)/sp*.md")
  if ($files | is-empty) {
    print "No sp### zettels"
    return
  }
  $files | each { |f|
    let content = (open --raw $f)
    let sp_id = ($f | path basename | str replace ".md" "")
    {
      sp_id: $sp_id
      name: (read_first_alias $content)
      status: (read_field $content "status")
      created: (read_field $content "created")
    }
  } | sort-by status sp_id
}

# Pass-through wrapper around the `akm-root` shell helper. Useful for shell
# embedding (`cd "$(akm root)"`) and for surfacing the strict-mode message
# the same way every other AKM tool does.
def "main root" [] {
  ^akm-root
}

# ----------------------------------------------------------------------------
# bd housekeeping helpers — cwd-rooted, NOT akm-root-rooted.
#
# bd Dolt state is repo-scoped (one .beads/ per repo, shared across worktrees
# via Dolt). These commands walk up from cwd to find `.beads/` rather than
# resolving the main worktree — that keeps them usable from any worktree for
# routine operations like `akm bd export` before a feature-branch commit.
# ----------------------------------------------------------------------------

def bd_project_root [] {
  mut cur = $env.PWD
  loop {
    if ($"($cur)/.beads" | path exists) {
      return $cur
    }
    let parent = ($cur | path dirname)
    if $parent == $cur {
      error make { msg: "Not inside a bd project (no .beads/ found walking up from PWD)" }
    }
    $cur = $parent
  }
}

def bd_archive_dir [] {
  let dir = $"(bd_project_root)/board/archive"
  mkdir $dir
  $dir
}

# Pin bd config keys that enforce the Dolt-canonical / manual-export model.
# Defensive — a fresh clone, `bd init` re-run, or future bd version that
# resets defaults would otherwise silently re-enable auto-export and we'd
# be back to the merge-clobber loop. Each `bd config set` is a no-op when
# the value already matches, so this is idempotent and silent on re-runs.
def bd_ensure_config [] {
  let desired = {
    "export.auto":      "false"                     # disable jsonl auto-write
    "export.git-add":   "false"                     # no auto-`git add`
    "export.path":      "issues-snapshot.jsonl"     # off bd's default-import watch path
    "dolt.auto-commit": "on"                        # commit Dolt writes so state persists
  }
  for kv in ($desired | transpose key value) {
    let current = try {
      (^bd config get $kv.key | complete).stdout | lines | last | str trim
    } catch { "" }
    if $current != $kv.value {
      print -e $"Setting bd config ($kv.key) = ($kv.value) \(was: ($current)\)"
      ^bd config set $kv.key $kv.value | ignore
    }
  }
}

# Remove bd's auto-installed hook shims and the legacy worktree-skip gate.
# Rationale: bd hooks auto-export Dolt → jsonl on every commit and auto-import
# jsonl → Dolt on every merge. With jsonl tracked in git, that turns every
# `git pull` into a state-clobber: a peer machine's older jsonl overwrites
# the local Dolt's freshly-closed status, silently reverting closures. We
# keep state in Dolt (manual `akm bd export` writes jsonl only when we want a
# history snapshot) and rely on `bd dolt push/pull` for cross-machine sync.
def bd_strip_hooks [root: string] {
  let hooks_dir = $"($root)/.git/hooks"
  if not ($hooks_dir | path exists) { return }

  # Ask bd to uninstall first — it knows where its shims live across versions.
  try {
    let status = (do { ^bd hooks list } | complete)
    if ($status.exit_code == 0) and ($status.stdout | str contains "✓") {
      print -e "Uninstalling bd auto-hooks (export/import is manual)..."
      ^bd hooks uninstall | ignore
    }
  } catch { }

  # Belt-and-suspenders: scrub any leftover markers and the worktree gate
  # from earlier init runs.
  for hook in [pre-commit post-merge post-checkout pre-push prepare-commit-msg] {
    let f = $"($hooks_dir)/($hook)"
    if not ($f | path exists) { continue }
    let content = (open --raw $f)
    let cleaned = (
      $content
      | str replace -r '(?s)# Skip bd hooks entirely when running from a linked worktree\..*?^fi\n' ''
      | str replace -r '(?s)# --- BEGIN BEADS INTEGRATION.*?# --- END BEADS INTEGRATION[^\n]*\n' ''
    )
    if $cleaned != $content {
      if (($cleaned | str trim) == "#!/usr/bin/env sh") or (($cleaned | str trim) == "") {
        rm $f
        print -e $"removed empty ($hook)"
      } else {
        $cleaned | save --force --raw $f
        print -e $"scrubbed ($hook)"
      }
    }
  }
}

def bd_preflight [] {
  if (which bd | is-empty) {
    error make { msg: "bd (beads) CLI not found on PATH — run infinifu/install.sh" }
  }
  let root = (bd_project_root)
  if not ($"($root)/.beads" | path exists) {
    error make { msg: $"($root)/.beads not found — run 'bd init' from the project root first" }
  }
  bd_strip_hooks $root
  bd_ensure_config
}

def "main bd" [] {
  print "akm bd — bd (beads) housekeeping"
  print ""
  print "Subcommands:"
  print "  akm bd init           strip bd auto-hooks, pin bd config (idempotent)"
  print "  akm bd export         bd Dolt → .beads/issues-snapshot.jsonl"
  print "  akm bd import         .beads/issues-snapshot.jsonl → bd Dolt"
  print "                          --force  skip confirmation"
  print "  akm bd archive create snapshot + prune old closed issues"
  print "                          --before <date>  cutoff (default: 365 days ago)"
  print "                          --yes            skip confirmation"
  print "  akm bd archive apply  apply cumulative prune-list to local bd"
  print ""
  print "Notes:"
  print "  - bd epic / task creation belongs to lifecycle skills (spec-ready, spec-retro),"
  print "    not this CLI. These commands are state plumbing only."
}

def "main bd init" [] {
  bd_preflight
  print -e "Repo ready: bd auto-hooks stripped, bd config pinned."
  print -e "Sync model: bd Dolt = canonical. Use `akm bd export` to refresh"
  print -e ".beads/issues-snapshot.jsonl before committing, `akm bd import` after a pull."
}

# Write current Dolt state to .beads/issues-snapshot.jsonl. Run before `git commit`
# when you want the jsonl snapshot to capture a status change.
def "main bd export" [] {
  cd (bd_project_root)
  ^bd export -o .beads/issues-snapshot.jsonl
  print -e "Exported bd Dolt → .beads/issues-snapshot.jsonl"
}

# Replay .beads/issues-snapshot.jsonl into the local Dolt. Run after `git pull` if you
# want the pulled jsonl (peer history) merged into your Dolt. Skip when you
# trust your local Dolt is more recent than what just arrived — that is the
# whole reason auto-import was removed.
def "main bd import" [
  --force  # skip confirmation
] {
  cd (bd_project_root)
  let jsonl = ".beads/issues-snapshot.jsonl"
  if not ($jsonl | path exists) {
    error make { msg: $"($jsonl) not found" }
  }
  if not $force {
    print -e $"Will replay ($jsonl) into local bd Dolt."
    print -e "This can resurrect closed issues if the jsonl is older than Dolt."
    let ans = (input "Proceed? [y/N]: ")
    if ($ans | str downcase) != "y" {
      print -e "Aborted"
      return
    }
  }
  ^bd import $jsonl
  print -e $"Imported ($jsonl) → bd Dolt"
}

def "main bd archive create" [
  --before: string  # ISO cutoff date (default: 365 days ago); archive closed issues closed before this
  --yes             # skip confirmation
] {
  cd (bd_project_root)
  let dir = (bd_archive_dir)
  let year = (date now | format date "%Y")
  let snap = $"($dir)/($year).jsonl"
  let prune = $"($dir)/prune-list"

  let cutoff_str = if ($before | is-empty) {
    (date now) - 365day | format date "%Y-%m-%d"
  } else {
    $before
  }

  let closed = try {
    ^bd list --json --status closed --limit 0 | from json
  } catch { [] }

  let to_archive = ($closed | where { |i|
    ($i.closed_at? | default "") != "" and ($i.closed_at < $cutoff_str)
  })

  if ($to_archive | is-empty) {
    print -e $"No closed issues with closed_at < ($cutoff_str) — nothing to archive."
    return
  }

  print -e $"Archiving ($to_archive | length) closed issues \(cutoff: ($cutoff_str)\):"
  $to_archive | select id title closed_at | table | print

  if not $yes {
    let ans = (input "Proceed? [y/N]: ")
    if ($ans | str downcase) != "y" {
      print -e "Aborted"
      return
    }
  }

  ^bd export --all | save -f $snap
  print -e $"Snapshot → ($snap)"

  let new_ids = ($to_archive | get id)
  let existing = if ($prune | path exists) {
    open --raw $prune | lines | where { |l| ($l | str trim) != "" }
  } else { [] }
  let merged = ($existing | append $new_ids | uniq | sort)
  $merged | str join "\n" | save -f $prune
  print -e $"Prune-list → ($prune) \(($merged | length) total IDs\)"

  let tmp = $"/tmp/bd-prune-(random uuid).txt"
  $new_ids | str join "\n" | save -f $tmp
  ^bd delete --from-file $tmp --force | ignore
  rm $tmp
  print -e $"Deleted ($new_ids | length) issues from local bd"

  ^bd export -o .beads/issues-snapshot.jsonl | ignore
  print -e "Refreshed .beads/issues-snapshot.jsonl"

  print -e ""
  print -e "Next: review `git status`, commit board/archive/ + .beads/issues-snapshot.jsonl, push."
}

def "main bd archive apply" [] {
  let prune = $"(bd_project_root)/board/archive/prune-list"
  if not ($prune | path exists) {
    print -e $"No prune-list at ($prune) — nothing to apply."
    return
  }

  let ids = (open --raw $prune | lines | where { |l| ($l | str trim) != "" })
  if ($ids | is-empty) {
    print -e "Prune-list is empty."
    return
  }

  let before = (try { ^bd list --json --all --limit 0 | from json | length } catch { 0 })
  ^bd delete --from-file $prune --force | ignore
  let after = (try { ^bd list --json --all --limit 0 | from json | length } catch { 0 })
  let deleted = ($before - $after)
  let missing = (($ids | length) - $deleted)
  print -e $"Applied prune-list: deleted ($deleted), already-gone ($missing) of ($ids | length)."
}

