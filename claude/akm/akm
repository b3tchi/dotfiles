  name: string             # alphanumeric / dash / underscore
  --category: string       # required: cat### id (validated against on-disk cat zettels)
  --title: string = ""     # default: <name> with dashes-to-spaces, title-cased
  --status: string = "Proposed"  # Proposed | Accepted | Deprecated | Superseded
  --stdin                 # read body from stdin (default: mint stub with empty sections)
] {
  validate_zettel_name $name
  if ($status not-in ["Proposed" "Accepted" "Deprecated" "Superseded"]) {
    error make { msg: $"--status must be one of Proposed | Accepted | Deprecated | Superseded, got `($status)`" }
  }
  let root = (require_akm_root)

  # Validate the category(ies) against on-disk cat zettels — refuse to mint
  # an ADR pointing at a dangling cat wikilink (the H1 link would 404 in
  # markdown-oxide). Shared with sp / ft via `parse_and_validate_cats`.
  let cats = (parse_and_validate_cats $root $category)

  # Upsert short-circuit — if any zettel already matches the alias or id
  # form, return that path. Mirrors `akm write` semantics so callers can
  # retry without pre-existence checks.
  let dupe = (find_zettel $root $name)
  if ($dupe != "") {
    print -e $"already exists with this alias: ($dupe)"
    return
  }

  # Pull body from stdin only when --stdin is set. Nu's `$in` doesn't
  # auto-capture script-invocation stdin (it's a pipeline construct);
  # we explicitly invoke `^cat` so the read is opt-in and never blocks
  # on a TTY when the caller forgets the flag. Skills that compose body
  # markdown will pipe via `printf ... | akm adr write ... --stdin`.
  let body = (if $stdin { (^cat | str trim) } else { "" })

  let id = (next_id $root "adr")
  let f = $"($root)/docs/notes/($id).md"
  let today = (date now | format date "%Y-%m-%d")

  let final_title = (if ($title | is-empty) {
    $name | str replace -a "-" " "
  } else {
    $title
  })

  # H1 convention across all typed zettels is the literal type word plus
  # categorization wikilinks (e.g. `# ADR [[cat001]] [[product]]`), not
  # the title. The title appears in `## title` below. This matches every
  # other zettel type (`# Story`, `# Feature`, `# Implementation`, …)
  # and what markdown-oxide expects when it resolves backlinks.
  #
  # Alias convention: the first `aliases:` entry is the title sentence,
  # not the slug — readers/find_zettel match against it as a display
  # string. We prefer `--title` (sentence) over `<name>` (slug) when
  # both are given, falling back to the slug only when title is empty.
  let alias_text = (if ($title | is-empty) { $name } else { $title })
  let parts = ([
    "---"
    "aliases:"
    $"  - ($alias_text)"
    $"status: ($status)"
    $"created: ($today)"
    "---"
    ""
    (compose_h1_with_links "ADR" $cats "product")
    ""
    "## title"
    $final_title
    ""
  ])
  let body_block = (if ($body == "") {
    [
      "## context"
      ""
      "## decision"
      ""
      "## consequences"
      ""
    ]
  } else {
    [$body ""]
  })
  let footer = [
    "---"
    ""
    "Index: [[product]]"
    ""
  ]

  ($parts | append $body_block | append $footer | str join "\n") | save -f $f

  # Stage on the default branch — ADRs are commit-on-creation per the
  # AKM commit policy. The actual commit is left to the skill
  # orchestrator so multi-file changes (ADR + product.md update) can
  # land as one commit.
  ^git -C $root add $"docs/notes/($id).md" | ignore

  # Print the allocated id as a structured first line so skills can
  # capture it with a single split instead of regex-parsing the path.
  print $"Id: ($id)"
  print -e $"Path: ($f)"
  print -e $"Staged docs/notes/($id).md"
}

