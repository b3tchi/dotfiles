# single `akm check` keeps surfacing every project-health signal in one
# go. Exit 0 even on warnings — diagnostics never gate.
def "main check" [] {
  let root = (require_akm_root)
  let notes = $"($root)/docs/notes"
  if not ($notes | path exists) {
    error make { msg: $"AKM not initialized in ($root) — run `akm init ($root)` first" }
  }
  print -e "→ cat taxonomy:"
  check_cat_collisions $notes (canonical_cats)
}

# ----------------------------------------------------------------------------
# bd housekeeping helpers — cwd-rooted, NOT akm-root-rooted.
#
# bd Dolt state is repo-scoped (one .beads/ per repo, shared across worktrees
# via Dolt). These commands walk up from cwd to find `.beads/` rather than
# resolving the main worktree — that keeps them usable from any worktree for
# routine operations like `akm bd export` before a feature-branch commit.
# ----------------------------------------------------------------------------

def bd_project_root [] {
  mut cur = $env.PWD
  loop {
    if ($"($cur)/.beads" | path exists) {
      return $cur
    }
    let parent = ($cur | path dirname)
    if $parent == $cur {
      error make { msg: "Not inside a bd project (no .beads/ found walking up from PWD)" }
    }
    $cur = $parent
  }
}

def bd_archive_dir [] {
  let dir = $"(bd_project_root)/board/archive"
  mkdir $dir
  $dir
}

# Pin bd config keys that enforce the Dolt-canonical / manual-export model.
# Defensive — a fresh clone, `bd init` re-run, or future bd version that
# resets defaults would otherwise silently re-enable auto-export and we'd
# be back to the merge-clobber loop. Each `bd config set` is a no-op when
# the value already matches, so this is idempotent and silent on re-runs.
def bd_ensure_config [] {
  let desired = {
    "export.auto":      "false"                     # disable jsonl auto-write
    "export.git-add":   "false"                     # no auto-`git add`
    "export.path":      "issues-snapshot.jsonl"     # off bd's default-import watch path
    "dolt.auto-commit": "on"                        # commit Dolt writes so state persists
  }
  for kv in ($desired | transpose key value) {
    let current = try {
      (^bd config get $kv.key | complete).stdout | lines | last | str trim
    } catch { "" }
    if $current != $kv.value {
      print -e $"Setting bd config ($kv.key) = ($kv.value) \(was: ($current)\)"
      ^bd config set $kv.key $kv.value | ignore
    }
  }
}

# Remove bd's auto-installed hook shims and the legacy worktree-skip gate.
# Rationale: bd hooks auto-export Dolt → jsonl on every commit and auto-import
# jsonl → Dolt on every merge. With jsonl tracked in git, that turns every
# `git pull` into a state-clobber: a peer machine's older jsonl overwrites
# the local Dolt's freshly-closed status, silently reverting closures. We
# keep state in Dolt (manual `akm bd export` writes jsonl only when we want a
# history snapshot) and rely on `bd dolt push/pull` for cross-machine sync.
# Return the list of git hooks that contain REAL bd auto-export/import logic
# (a non-comment line invoking `bd export|import|hooks run`). bd / partial
# strips can leave an inert worktree-gate stub behind — that is harmless and
# must NOT be flagged as a race vector. Only a body with an actual bd command
# re-introduces the auto-flush clobber.
def bd_race_hooks [root: string] {
  let hooks_dir = $"($root)/.git/hooks"
  if not ($hooks_dir | path exists) { return [] }
  ["pre-commit" "post-merge" "post-checkout" "pre-push" "prepare-commit-msg"] | where { |h|
    let f = $"($hooks_dir)/($h)"
    ($f | path exists) and (
      open --raw $f | lines
      | where { |l| not ($l | str trim | str starts-with "#") }
      | any { |l| ($l =~ 'bd +(export|import|hooks +run)') }
    )
  }
}

def bd_strip_hooks [root: string] {
  let hooks_dir = $"($root)/.git/hooks"
  if not ($hooks_dir | path exists) { return }

  # Ask bd to uninstall first — it knows where its shims live across versions.
  try {
    let status = (do { ^bd hooks list } | complete)
    if ($status.exit_code == 0) and ($status.stdout | str contains "✓") {
      print -e "Uninstalling bd auto-hooks (export/import is manual)..."
      ^bd hooks uninstall | ignore
    }
  } catch { }

  # Belt-and-suspenders: scrub any leftover markers and the worktree gate
  # from earlier init runs.
  for hook in [pre-commit post-merge post-checkout pre-push prepare-commit-msg] {
    let f = $"($hooks_dir)/($hook)"
    if not ($f | path exists) { continue }
    let content = (open --raw $f)
    let cleaned = (
      $content
      | str replace -r '(?s)# Skip bd hooks entirely when running from a linked worktree\..*?^fi\n' ''
      | str replace -r '(?s)# --- BEGIN BEADS INTEGRATION.*?# --- END BEADS INTEGRATION[^\n]*\n' ''
    )
    if $cleaned != $content {
      if (($cleaned | str trim) == "#!/usr/bin/env sh") or (($cleaned | str trim) == "") {
        rm $f
        print -e $"removed empty ($hook)"
      } else {
        $cleaned | save --force --raw $f
        print -e $"scrubbed ($hook)"
      }
    }
  }
}

# Resolve the Dolt server connection (db name + port) from .beads metadata.
# db <- metadata.json.dolt_database, port <- dolt-server.port. Both are
# written by bd on server start; absent on embedded-mode or pre-start repos.
def bd_dolt_conn [] {
  let root = (bd_project_root)
  let meta = $"($root)/.beads/metadata.json"
  let portf = $"($root)/.beads/dolt-server.port"
  let db = (if ($meta | path exists) { (open $meta | get -o dolt_database | default "") } else { "" })
  let port = (if ($portf | path exists) { (open $portf | into string | str trim) } else { "" })
  { db: $db, port: $port }
}

# Run a query against the project's Dolt server, returning parsed CSV rows
# (empty list on no rows). Errors if db/port can't be resolved.
def bd_dolt_q [query: string] {
  let c = (bd_dolt_conn)
  if ($c.db == "") or ($c.port == "") {
    error make { msg: "cannot resolve Dolt db/port from .beads (metadata.json / dolt-server.port) — is the server running?" }
  }
  (^dolt --host 127.0.0.1 --port $c.port --user root --no-tls --password "" --use-db $c.db sql -q $query -r csv
    | complete | get stdout | from csv)
}

# Execute a (possibly multi-statement) DDL/DML query against Dolt. No result.
def bd_dolt_exec [query: string] {
  let c = (bd_dolt_conn)
  if ($c.db == "") or ($c.port == "") {
    error make { msg: "cannot resolve Dolt db/port from .beads (metadata.json / dolt-server.port) — is the server running?" }
  }
  ^dolt --host 127.0.0.1 --port $c.port --user root --no-tls --password "" --use-db $c.db sql -q $query | ignore
}

def bd_has_table [name: string] {
  let c = (bd_dolt_conn)
  ((bd_dolt_q $"SELECT table_name FROM information_schema.tables WHERE table_schema = '($c.db)' AND table_name = '($name)'") | length) > 0
}

def bd_has_column [table: string, col: string] {
  let c = (bd_dolt_conn)
  ((bd_dolt_q $"SELECT column_name FROM information_schema.columns WHERE table_schema = '($c.db)' AND table_name = '($table)' AND column_name = '($col)'") | length) > 0
}

# Recreate bd's wisp tables when absent. They're listed in dolt_ignore, so a
# fresh `bd bootstrap`/clone never restores them and bd's post-clone store
# init can fail ("table not found: wisps"), which blocks every later schema
# migration. DDL mirrors bd migrations 0020-0022; CREATE IF NOT EXISTS makes
# this a no-op once present. (auctions recovery 2026-05-30.)
def bd_ensure_wisps [] {
  if (bd_has_table "wisps") { return false }
  print -e "Recreating missing wisp tables (dolt_ignored, not restored by clone)..."
  bd_dolt_exec (bd_wisp_ddl)
  true
}

