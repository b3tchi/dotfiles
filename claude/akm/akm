# Health-check + self-heal the bd/Dolt state for this repo. Idempotent:
# verifies the server is reachable, the config pins / hook-strip are in place,
# and the per-clone Dolt schema fixups (wisp tables, perles depends_on_id
# compat column) are present — repairing each in place. Run after a fresh
# clone / `bd bootstrap`, or whenever perles shows an empty board or bd errors
# with "table not found: wisps".
def "main bd doctor" [
  --diagnose  # report only; do NOT self-heal (read-only audit)
] {
  let root = (bd_project_root)
  print -e $"akm bd doctor — ($root)"

  # Server reachability
  let conn = (bd_dolt_conn)
  if ($conn.db == "") or ($conn.port == "") {
    print -e "  ✖ Dolt server: cannot resolve db/port from .beads (server not started?)"
    print -e "    run `bd dolt start` (or any bd command) first, then re-run doctor"
    return
  }
  let reachable = (try { (bd_dolt_q "SELECT 1 AS ok" | length) >= 0 } catch { false })
  if not $reachable {
    print -e $"  ✖ Dolt server: unreachable at 127.0.0.1:($conn.port) db=($conn.db)"
    return
  }
  print -e $"  ✓ Dolt server: ($conn.db) @ 127.0.0.1:($conn.port)"

  # Config pins + hook strip
  if $diagnose {
    let race = (bd_race_hooks $root)
    print -e (if ($race | is-empty) { "  ✓ no auto-export/import hook logic" } else { $"  ✖ race hooks with bd logic: ($race | str join ', ') — run `akm bd doctor` to strip" })
    let want = { "export.auto": "false", "export.git-add": "false", "export.path": "issues-snapshot.jsonl", "dolt.auto-commit": "on" }
    for kv in ($want | transpose key value) {
      let cur = (try { (^bd config get $kv.key | complete).stdout | lines | last | str trim } catch { "" })
      print -e (if $cur == $kv.value { $"  ✓ ($kv.key) = ($kv.value)" } else { $"  ✖ ($kv.key) = ($cur) \(want ($kv.value)\) — run `akm bd doctor` to pin" })
    }
  } else {
    bd_strip_hooks $root
    bd_ensure_config
    let race = (bd_race_hooks $root)
    print -e (if ($race | is-empty) { "  ✓ config pinned, no auto-export/import hook logic" } else { $"  ✖ config pinned, but race hooks persist: ($race | str join ', ') — bd is regenerating them" })
  }

  # Per-clone schema fixups
  if $diagnose {
    print -e (if (bd_has_table "wisps") { "  ✓ wisp tables present" } else { "  ✖ wisp tables missing — run `akm bd doctor` to recreate" })
    let perles_ok = (if (bd_has_table "dependencies") {
      (bd_has_column "dependencies" "depends_on_id") or (not (bd_has_column "dependencies" "depends_on_issue_id"))
    } else { true })
    print -e (if $perles_ok { "  ✓ perles compat column ok (or n/a)" } else { "  ✖ perles depends_on_id compat column missing — run `akm bd doctor` to add" })
  } else {
    let w = (bd_ensure_wisps)
    print -e (if $w { "  ⚙ wisp tables recreated" } else { "  ✓ wisp tables present" })
    let p = (bd_ensure_perles_compat)
    print -e (if $p { "  ⚙ perles depends_on_id compat column added" } else { "  ✓ perles compat column ok (or n/a)" })
    if ($w or $p) {
      bd_dolt_exec "CALL dolt_add('-A'); CALL dolt_commit('-m', 'akm bd doctor: per-clone Dolt schema fixups (wisps / perles compat)');"
      print -e "  ⚙ committed schema fixups to Dolt"
    }
  }
  # Git-side hygiene (read-only) — snapshot committed, legacy path retired,
  # snapshot fresh vs Dolt, optional dolt transport configured.
  let snap_tracked = ((do { ^git -C $root ls-files --error-unmatch .beads/issues-snapshot.jsonl } | complete).exit_code == 0)
  print -e (if $snap_tracked { "  ✓ issues-snapshot.jsonl tracked" } else { "  ✖ issues-snapshot.jsonl not tracked — run `akm bd export` then git add" })
  let legacy_tracked = ((do { ^git -C $root ls-files --error-unmatch .beads/issues.jsonl } | complete).exit_code == 0)
  print -e (if $legacy_tracked { "  ✖ legacy issues.jsonl tracked — stale-import hazard; git rm --cached + gitignore it" } else { "  ✓ legacy issues.jsonl not tracked" })
  let remote = try { (^bd config get sync.remote | complete).stdout | lines | last | str trim } catch { "" }
  print -e (if ($remote | is-empty) { "  ⚠ sync.remote unset — dolt push/pull unavailable (jsonl snapshot still works)" } else { $"  ✓ sync.remote = ($remote)" })
  let snap = $"($root)/.beads/issues-snapshot.jsonl"
  if ($snap | path exists) {
    let live = (try { bd_export_closed | sort } catch { [] })
    let committed = (open --raw $snap | lines | where { |l| ($l | str trim) != "" } | sort)
    print -e (if $live == $committed { "  ✓ snapshot in sync with Dolt (closed issues)" } else { "  ⚠ snapshot stale vs Dolt closed set — run `akm bd export` + commit" })
  }
  # Legacy / pre-migration artifacts that survive the config self-heal and can
  # re-introduce the auto-flush race — especially on a fresh clone.
  let tracked_hooks = (do { ^git -C $root ls-files .beads/hooks } | complete | get stdout | lines | where { |l| ($l | str trim) != "" })
  if ($tracked_hooks | is-empty) {
    print -e "  ✓ no tracked bd hook templates"
  } else {
    print -e $"  ⚠ ($tracked_hooks | length) tracked .beads/hooks templates re-install the auto-flush race on clone — `git rm -r --cached .beads/hooks` + gitignore"
  }
  if ($"($root)/.beads/issues.jsonl" | path exists) {
    print -e "  ⚠ on-disk .beads/issues.jsonl present — bd may auto-import it; remove (Dolt canonical, snapshot is issues-snapshot.jsonl)"
  } else {
    print -e "  ✓ no on-disk legacy issues.jsonl"
  }
  let cfg = $"($root)/.beads/config.yaml"
  let legacy_keys = (if ($cfg | path exists) {
    ["no-auto-flush" "no-auto-import" "no-db" "no-daemon"] | where { |k|
      (open --raw $cfg | lines | any { |l| ($l | str starts-with $"($k):") })
    }
  } else { [] })
  if ($legacy_keys | is-empty) {
    print -e "  ✓ no legacy no-db-mode config keys"
  } else {
    print -e $"  ⚠ stale pre-Dolt config keys: ($legacy_keys | str join ', ') — harmless but obsolete, safe to delete from config.yaml"
  }

  # perles config is global-only (~/.config/perles/config.yaml, symlinked from
  # dotfiles). A local .perles/ (from `perles init`) shadows the global config
  # per-repo — strip it so every repo shares one board config. Self-heal.
  let local_perles = $"($root)/.perles"
  if ($local_perles | path exists) {
    if $diagnose {
      print -e "  ✖ local .perles/ present — shadows global config; run `akm bd doctor` to strip"
    } else {
      rm -rf $local_perles
      print -e "  ⚙ stripped local .perles/ — perles uses global ~/.config/perles/config.yaml"
    }
  } else {
    print -e "  ✓ no local perles config (global only)"
  }

  if $diagnose {
    print -e "Diagnosis complete (read-only). Any ✖/⚠ above are fixed by `akm bd doctor` (no --diagnose)."
  } else {
    print -e "Healthy."
  }
}

# Top-level alias so `akm doctor` / `akm healthcheck` reach the bd healthcheck.
def "main doctor" [--diagnose] { if $diagnose { main bd doctor --diagnose } else { main bd doctor } }
def "main healthcheck" [] { main bd doctor }

# Closed-only export lines from bd. Snapshot policy: live (open/in_progress)
# state lives ONLY in Dolt (synced via `bd dolt push/pull`); git archives just
# the closed history — human-readable, tool-independent, diffable next to code.
def bd_export_closed [] {
  ^bd export | lines | where { |l|
    ($l | str trim) != "" and (($l | from json | get status) == "closed")
  }
}

# Rewrite .beads/issues-snapshot.jsonl (closed issues only). Returns count.
def bd_write_snapshot [] {
  let closed = (bd_export_closed)
  let body = if ($closed | is-empty) { "" } else { ($closed | str join "\n") + "\n" }
  $body | save -f .beads/issues-snapshot.jsonl
  $closed | length
}

# Write closed issues to .beads/issues-snapshot.jsonl. Run before `git commit`
# when closes happened. Live issues are NOT in the jsonl — Dolt is canonical.
def "main bd export" [] {
  cd (bd_project_root)
  let n = (bd_write_snapshot)
  print -e $"Exported ($n) closed issues → .beads/issues-snapshot.jsonl \(live state stays in Dolt\)"
}

# Replay .beads/issues-snapshot.jsonl (closed-issue archive) into the local
# Dolt. Recovery path only — restores closed history, NOT live issues (those
# exist solely in Dolt / refs/dolt/data). Skip when local Dolt is healthy.
def "main bd import" [
  --force  # skip confirmation
] {
  cd (bd_project_root)
  let jsonl = ".beads/issues-snapshot.jsonl"
  if not ($jsonl | path exists) {
    error make { msg: $"($jsonl) not found" }
  }
  if not $force {
    print -e $"Will replay ($jsonl) into local bd Dolt."
    print -e "This can resurrect closed issues if the jsonl is older than Dolt."
    let ans = (input "Proceed? [y/N]: ")
    if ($ans | str lowercase) != "y" {
      print -e "Aborted"
      return
    }
  }
  bd_ensure_schema
  ^bd import $jsonl
  print -e $"Imported ($jsonl) → bd Dolt"
}

def "main bd archive create" [
  --before: string  # ISO cutoff date (default: 365 days ago); archive closed issues closed before this
  --yes             # skip confirmation
] {
  cd (bd_project_root)
  let dir = (bd_archive_dir)
  let year = (date now | format date "%Y")
  let snap = $"($dir)/($year).jsonl"
  let prune = $"($dir)/prune-list"

  let cutoff_str = if ($before | is-empty) {
    (date now) - 365day | format date "%Y-%m-%d"
  } else {
    $before
  }

  let closed = try {
    ^bd list --json --status closed --limit 0 | from json
  } catch { [] }

  let to_archive = ($closed | where { |i|
    ($i.closed_at? | default "") != "" and ($i.closed_at < $cutoff_str)
  })

  if ($to_archive | is-empty) {
    print -e $"No closed issues with closed_at < ($cutoff_str) — nothing to archive."
    return
  }

  print -e $"Archiving ($to_archive | length) closed issues \(cutoff: ($cutoff_str)\):"
  $to_archive | select id title closed_at | table | print

  if not $yes {
    let ans = (input "Proceed? [y/N]: ")
    if ($ans | str lowercase) != "y" {
      print -e "Aborted"
      return
    }
  }

  ^bd export --all | save -f $snap
  print -e $"Snapshot → ($snap)"

  let new_ids = ($to_archive | get id)
  let existing = if ($prune | path exists) {
    open --raw $prune | lines | where { |l| ($l | str trim) != "" }
  } else { [] }
  let merged = ($existing | append $new_ids | uniq | sort)
  $merged | str join "\n" | save -f $prune
  print -e $"Prune-list → ($prune) \(($merged | length) total IDs\)"

  let tmp = $"/tmp/bd-prune-(random uuid).txt"
  $new_ids | str join "\n" | save -f $tmp
  ^bd delete --from-file $tmp --force | ignore
  rm $tmp
  print -e $"Deleted ($new_ids | length) issues from local bd"

  bd_write_snapshot | ignore
  print -e "Refreshed .beads/issues-snapshot.jsonl (closed issues)"

  print -e ""
  print -e "Next: review `git status`, commit board/archive/ + .beads/issues-snapshot.jsonl, push."
}

def "main bd archive apply" [] {
  let prune = $"(bd_project_root)/board/archive/prune-list"
  if not ($prune | path exists) {
    print -e $"No prune-list at ($prune) — nothing to apply."
    return
  }

  let ids = (open --raw $prune | lines | where { |l| ($l | str trim) != "" })
  if ($ids | is-empty) {
    print -e "Prune-list is empty."
    return
  }

  let before = (try { ^bd list --json --all --limit 0 | from json | length } catch { 0 })
  ^bd delete --from-file $prune --force | ignore
  let after = (try { ^bd list --json --all --limit 0 | from json | length } catch { 0 })
  let deleted = ($before - $after)
  let missing = (($ids | length) - $deleted)
  print -e $"Applied prune-list: deleted ($deleted), already-gone ($missing) of ($ids | length)."
}

