#!/usr/bin/env nu
# akm — manage markdown-oxide PKM workspaces (AKM zettelkasten) and the
# bd (beads) state plumbing that backs them.
#
# AKM subcommands (zettel + board lifecycle):
#   akm init <target>     bootstrap (or re-link) PKM under <target>/docs/
#   akm create <name>     mint sp### at status:idea + board.md ## idea entry
#   akm delete <name>     delete sp### + remove board.md entry
#   akm list              show all sp### grouped by status
#   akm root              print AKM workspace root (wraps the akm-root helper)
#
# bd housekeeping (`akm bd ...`):
#   akm bd init           strip bd auto-hooks, pin bd config, heal schema (per repo)
#   akm bd doctor         health-check + self-heal Dolt state (also: akm doctor)
#                         (--diagnose = read-only audit, no heal)
#   akm bd export         bd Dolt closed issues → .beads/issues-snapshot.jsonl (archive)
#   akm bd import         .beads/issues-snapshot.jsonl → bd Dolt (closed-history recovery)
#   akm bd archive create snapshot + prune old closed issues
#   akm bd archive apply  apply prune-list on other machines
#
# Examples:
#   akm init .                       # init current repo
#   akm create rotate-credentials    # mint sp025 (or next id) at status:idea
#   akm delete sp025                 # remove by id
#   akm list                         # idea / spec / ready / done buckets
#   akm bd init                      # bd hook strip + config pin
#   akm bd export                    # snapshot Dolt before commit
#
# Env overrides:
#   AKM_SOURCE          absolute path to canonical akm.md
#                       default: ~/.dotfiles/claude/akm/akm.md
#   AKM_ROOT_OVERRIDE   force a workspace path (testing / non-standard layouts)
#
# Design contract — bd epic / task LIFECYCLE is out of scope here:
#   `akm bd ...` is bd state PLUMBING only (hook strip, jsonl snapshot/restore,
#   archival pruning). Beads (bd) epic creation, task minting, and closure
#   happen in the lifecycle skills (`spec-ready` mints the bd epic and child
#   tasks when sp### → ready; `spec-retro` closes them when sp### → done).
#   Keeping lifecycle out of the CLI means the AKM data model stays coherent
#   regardless of which work-tracker the team uses.
#
# Workspace resolution — strict main-worktree rule:
#   Every AKM zettel operation (read, search, write) resolves its workspace
#   via the `akm-root` helper. From a feature worktree akm-root refuses with
#   exit 2 and stderr explaining where to `cd`. This CLI surfaces that
#   message verbatim. AKM zettels live on the default branch; feature
#   worktrees exist only for code work (work-do / work-audit / work-merge).
#   bd housekeeping commands (`akm bd ...`) use a separate `bd_project_root`
#   resolver — bd Dolt state is repo-scoped, not branch-scoped, so they work
#   from any worktree.

# Resolve the AKM workspace root via the `akm-root` shell helper.
#   exit 0 → return path (cwd is inside the main worktree of an AKM repo)
#   exit 1 → return ""   (no AKM workspace — non-AKM repo or no default branch)
#   exit 2 → raise       (strict refusal — cwd is on a feature worktree;
#                         caller surfaces the helper's stderr to the user)
def akm_root [] {
  let r = (do { ^akm-root } | complete)
  if $r.exit_code == 0 {
    $r.stdout | str trim
  } else if $r.exit_code == 2 {
    error make { msg: ($r.stderr | str trim) }
  } else {
    ""
  }
}

# Require an initialized AKM workspace and return its root.
# Errors with a hint when called from a non-AKM repo or before `akm init`.
def require_akm_root [] {
  let root = (akm_root)
  if ($root == "") {
    error make { msg: "no AKM workspace (no default branch detected) — run `akm init .` first" }
  }
  let docs = $"($root)/docs"
  if not ($docs | path exists) {
    error make { msg: $"AKM not initialized in ($root) — run `akm init ($root)` first" }
  }
  $root
}

# Per-type AKM schema. Each typed zettel has a stable id prefix, a directory
# it lives under (relative to the AKM root), a default status for fresh
# stubs, a list of `##` body section headers it expects, and (for sp only)
# the board.md section to register itself under. Returns the schema record
# or raises on unknown type so the CLI fails fast with a useful list.
def type_schema [t: string] {
  match $t {
    "sp"  => { type: "sp",  dir: "docs/notes/spec", digits: 3, status: "idea",     index: "board",
               sections: ["## problem"],                                                                         board: "idea" }
    "us"  => { type: "us",  dir: "docs/notes",      digits: 3, status: "draft",    index: "product",
               sections: ["## role" "## want" "## because" "## acceptance_criteria"],                            board: "" }
    "pn"  => { type: "pn",  dir: "docs/notes",      digits: 3, status: "draft",    index: "product",
               sections: ["## name" "## summary" "## primary_goals" "## open_questions"],                        board: "" }
    "ft"  => { type: "ft",  dir: "docs/notes",      digits: 3, status: "proposed", index: "product",
               sections: ["## providing" "## api_surface" "## data_model" "## sample" "## components"],         board: "" }
    "im"  => { type: "im",  dir: "docs/notes",      digits: 3, status: "proposed", index: "product",
               sections: ["## solves" "## approach" "## features" "## data_model" "## api_surface" "## components" "## specs"], board: "" }
    "adr" => { type: "adr", dir: "docs/notes",      digits: 4, status: "Proposed", index: "product",
               sections: ["## context" "## decision" "## consequences"],                                         board: "" }
    "cat" => { type: "cat", dir: "docs/notes",      digits: 3, status: "stable",   index: "product",
               sections: ["## name" "## summary" "## scope_notes"],                                              board: "" }
    "poc" => { type: "poc", dir: "docs/notes/lab",  digits: 3, status: "open",      index: "board",
               sections: ["## informs" "## hypothesis" "## method" "## result" "## recommendation"],             board: "" }
    _ => { error make { msg: $"unknown AKM type `($t)` — valid: sp us pn ft im adr cat poc" } }
  }
}

# All AKM type prefixes, used when scanning for a zettel by id or alias.
def type_prefixes [] { ["sp" "us" "pn" "ft" "im" "adr" "cat" "poc"] }

# The canonical 8-category taxonomy — single source of truth for both the
# `akm init` scaffolding pass and the collision check that runs when a
# project already has cat### files. Index 0 → cat001, index 7 → cat008.
def canonical_cats [] {
  [
    "Technology choices"      # cat001
    "Architecture patterns"   # cat002
    "API design"              # cat003
    "Data modeling"           # cat004
    "Infrastructure"          # cat005
    "Security"                # cat006
    "Testing"                 # cat007
    "Process"                 # cat008
  ]
}

# Compare existing cat### files under <notes_dir> against the canonical
# taxonomy and print warnings for each mismatch:
#   - same id, different first-alias  → "cat001 alias 'workflow-tooling' != canonical 'Technology choices'"
#   - id missing                      → "cat003 missing (canonical: 'API design')"
#   - extra id past cat008            → "cat009 'foo' not in canonical taxonomy"
# Silent when fully aligned. Used by `akm init` and exposed via `akm check cat`.
def check_cat_collisions [notes_dir: string, canonical: list<string>] {
  mut mismatches = 0

  # Walk canonical slots: warn on missing or alias mismatch.
  for entry in ($canonical | enumerate) {
    let n = ($entry.index + 1)
    let id = $"cat(($n) | fill -a r -c '0' -w 3)"
    let expected = $entry.item
    let f = $"($notes_dir)/($id).md"
    if not ($f | path exists) {
      print -e $"⚠ ($id) missing — canonical: '($expected)'"
      $mismatches = ($mismatches + 1)
      continue
    }
    let actual = (read_first_alias (open --raw $f))
    if $actual != $expected {
      print -e $"⚠ ($id) alias '($actual)' != canonical '($expected)'"
      $mismatches = ($mismatches + 1)
    }
  }

  # Walk all existing cat### files: warn on ids past the canonical range.
  let max = ($canonical | length)
  let files = (glob $"($notes_dir)/cat*.md")
  for f in $files {
    let id = ($f | path basename | str replace ".md" "")
    let num_str = ($id | str substring 3..)
    let num = (try { $num_str | into int } catch { 0 })
    if $num > $max {
      let alias = (read_first_alias (open --raw $f))
      print -e $"⚠ ($id) '($alias)' not in canonical taxonomy (extends past cat(($max) | fill -a r -c '0' -w 3))"
      $mismatches = ($mismatches + 1)
    }
  }

  if $mismatches > 0 {
    print -e $"     ($mismatches) collisions — rename / supersede / extend per project policy"
  }
}

# Glob <prefix>NNN.md (or NNNN.md for adr) under the schema's dir and return
# the next zero-padded id. Robust to gaps — picks max + 1, not count + 1.
# Creates the dir on first use so a freshly initialized AKM workspace can
# mint the first zettel without a separate scaffolding step.
def next_id [root: string, prefix: string] {
  let s = (type_schema $prefix)
  let dir = $"($root)/($s.dir)"
  if not ($dir | path exists) { mkdir $dir }
  let existing = (glob $"($dir)/($prefix)*.md")
  let plen = ($prefix | str length)
  let nums = ($existing | each { |f|
    let base = ($f | path basename | str replace ".md" "")
    let num_str = ($base | str substring $plen..)
    # Some files may have suffixes after the digits (none expected today,
    # but be defensive). into int parses leading digits.
    try { $num_str | into int } catch { 0 }
  })
  let next = (if ($nums | is-empty) { 1 } else { ($nums | math max) + 1 })
  let padded = ($next | fill -a r -c '0' -w $s.digits)
  $"($prefix)($padded)"
}

# Shared by every typed `<type> write` — the first-alias / slug rule. Names
# become `aliases[0]` and (for some types) the find_zettel match key, so they
# must stay path- and wikilink-safe. Raises on violation so the CLI fails
# fast the same way for every type.
def validate_zettel_name [name: string] {
  if not ($name =~ '^[a-zA-Z0-9_-]+$') {
    error make { msg: "name must contain only alphanumeric characters, dashes, and underscores" }
  }
}

# Compose + stage a *tagless* typed zettel (H1 carries only `[[product]]`,
# no `[[cat###]]`). Shared by the two tagless writers — `cat` and `pn` —
# extracted on the second landing per sp004's incremental "helpers per pair"
# plan. The caller owns the per-type bits: status value, the H1 type word,
# and the stub body section list. Allocates the id, writes frontmatter + H1
# + (stdin body or stub) + footer, stages on the default branch, and prints
# the structured `Id: <id>` line skills capture. Returns nothing — the id is
# on stdout.
def compose_tagless_zettel [
  root: string
  prefix: string         # "cat" | "pn"
  type_word: string      # "Category" | "Persona"
  name: string           # first alias
  status: string         # frontmatter status (cat: stable; pn: draft/validated/retired)
  stub: list<string>     # body lines used when no --stdin body was piped
  body: string           # stdin body, or "" to fall back to stub
] {
  let id = (next_id $root $prefix)
  let f = $"($root)/docs/notes/($id).md"
  let today = (date now | format date "%Y-%m-%d")

  let parts = ([
    "---"
    "aliases:"
    $"  - ($name)"
    $"status: ($status)"
    $"created: ($today)"
    "---"
    ""
    $"# ($type_word) [[product]]"
    ""
  ])
  let body_block = (if ($body == "") { $stub } else { [$body ""] })
  let footer = [
    "---"
    ""
    "Index: [[product]]"
    ""
  ]

  ($parts | append $body_block | append $footer | str join "\n") | save -f $f

  ^git -C $root add $"docs/notes/($id).md" | ignore

  print $"Id: ($id)"
  print -e $"Path: ($f)"
  print -e $"Staged docs/notes/($id).md"
}

# Parse a comma-separated --category string into a validated list of cat###
# ids. Shared by every *categorized* writer (adr / sp / ft) — extracted on
# the ft landing once there were three categorized types duplicating the
# same parse + form-check + dangling-link guard. Errors (never returns a
# bad list) so callers can trust the result. Refuses an empty list, a
# malformed id, or a cat### with no file on disk (the H1 link would 404 in
# markdown-oxide).
def parse_and_validate_cats [root: string, category: string] {
  if ($category | is-empty) {
    error make { msg: "--category is required (e.g. --category cat003 or --category cat003,cat006)" }
  }
  let cats = ($category | split row "," | each { |c| $c | str trim } | where { |c| not ($c | is-empty) })
  if ($cats | is-empty) {
    error make { msg: "--category is required (e.g. --category cat003 or --category cat003,cat006)" }
  }
  for c in $cats {
    if not ($c =~ '^cat\d{3}$') {
      error make { msg: $"--category entries must be cat### form, got `($c)`" }
    }
    let cat_file = $"($root)/docs/notes/($c).md"
    if not ($cat_file | path exists) {
      error make { msg: $"category ($c) not found at ($cat_file) — run `akm cat list` to see existing categories" }
    }
  }
  $cats
}

# Build an H1 line: `# <Word> [[link]] [[link]]... [[index]]`. The leading
# links are either validated categories (adr / sp / ft, via
# `parse_and_validate_cats`) or arbitrary tag slugs (us, which may dangle).
# `index_target` is the hub the type indexes under — `product` for adr / ft /
# us, `board` for sp. An empty `links` list yields `# <Word> [[index]]`
# (no double space), so a tagless story is still well-formed.
def compose_h1_with_links [type_word: string, links: list<string>, index_target: string] {
  let all = ($links | each { |c| $"[[($c)]]" } | append $"[[($index_target)]]" | str join " ")
  $"# ($type_word) ($all)"
}

# Insert `- [[sp_id|name]]` under `## idea` of docs/board.md. Idempotent —
# skips if the wikilink already exists anywhere in the file. The board.md
# must already have `## idea` / `## spec` / `## ready` sections (created by
# `akm init`); a missing section is surfaced as a no-op with a warning so
# the user can fix the file before retrying.
def add_to_board_idea [board: string, sp_id: string, name: string] {
  let content = (open --raw $board)
  if ($content | str contains $"[[($sp_id)|") { return }
  let lines = ($content | lines)
  let idea_idx = ($lines | enumerate | where { |it| $it.item == "## idea" } | get -o 0.index)
  if ($idea_idx == null) {
    print -e $"warn: ($board) missing `## idea` section — sp### entry not inserted"
    return
  }
  let insert_at = ($idea_idx + 1)
  let link = $"- [[($sp_id)|($name)]]"
  let new_lines = (
    ($lines | take $insert_at)
    | append ""
    | append $link
    | append ($lines | skip $insert_at)
  )
  ($new_lines | str join "\n") | save -f $board
}

# Strip a single `[[sp_id|...]]` line from board.md. Also collapses runs
# of more than one consecutive blank line that result from the removal so
# add/remove cycles don't accumulate whitespace under `## idea`.
def remove_from_board [board: string, sp_id: string] {
  if not ($board | path exists) { return }
  let pat = $"[[($sp_id)|"
  let kept = (open --raw $board | lines | where { |l| not ($l | str contains $pat) })
  # Collapse adjacent blank lines (drop a blank if the previous kept line is also blank).
  let collapsed = ($kept | reduce --fold [] { |line, acc|
    let prev = ($acc | last)
    if ($line == "") and ($prev == "") { $acc } else { $acc | append $line }
  })
  (($collapsed | str join "\n") + "\n") | save -f $board
}

# Parse YAML frontmatter (first --- ... --- block) into a list of "key: value" lines.
def frontmatter [content: string] {
  let lines = ($content | lines)
  if ($lines | is-empty) or ($lines | first) != "---" {
    return []
  }
  let rest = ($lines | skip 1)
  let end = ($rest | enumerate | where item == "---" | get -o 0.index)
  if ($end | is-empty) { return [] }
  $rest | take $end
}

# Read a top-level scalar field from frontmatter ("status: idea" → "idea").
# Returns "" when key absent. Aliases (a list) need separate parsing.
def read_field [content: string, key: string] {
  let fm = (frontmatter $content)
  let matches = ($fm | where { |l| $l | str starts-with $"($key):" })
  if ($matches | is-empty) {
    ""
  } else {
    $matches | first | str replace $"($key):" "" | str trim
  }
}

# Read the first alias entry from frontmatter:
#   aliases:
#     - foo
#     - bar
# Returns "foo" or "" when block absent. First alias is the canonical name
# the user passed to `akm create`.
def read_first_alias [content: string] {
  let lines = (frontmatter $content)
  let idx = ($lines | enumerate | where { |it| ($it.item | str trim) == "aliases:" } | get -o 0.index)
  if ($idx == null) { return "" }
  let after = ($lines | skip ($idx + 1))
  let first_item = ($after | first)
  if ($first_item == null) { return "" }
  let s = ($first_item | str trim)
  if ($s | str starts-with "- ") {
    $s | str replace -r '^- ' '' | str trim
  } else {
    ""
  }
}

# Find any typed zettel by id ("sp025", "adr0010", "us003", ...) or by its
# first alias. Returns absolute path or "" when no match. Looks up the type
# from the id prefix when present; otherwise scans every type's directory
# for an alias match. Designed for `akm delete <key>` and similar lookups
# where the caller doesn't know the type up front.
def find_zettel [root: string, key: string] {
  # Try id form first: prefix + digits.
  for p in (type_prefixes) {
    if ($key | str starts-with $p) {
      let tail = ($key | str substring ($p | str length)..)
      if ($tail =~ '^\d+$') {
        let s = (type_schema $p)
        let f = $"($root)/($s.dir)/($key).md"
        if ($f | path exists) { return $f }
      }
    }
  }
  # Alias fallback — scan every type's directory.
  for p in (type_prefixes) {
    let s = (type_schema $p)
    let dir = $"($root)/($s.dir)"
    if not ($dir | path exists) { continue }
    for f in (glob $"($dir)/($p)*.md") {
      let content = (open --raw $f)
      let alias = (read_first_alias $content)
      if $alias == $key { return $f }
    }
  }
  ""
}

def "main init" [target: string] {
  let akm_source = ($env.AKM_SOURCE? | default $"($env.HOME)/.dotfiles/claude/akm/akm.md")

  if not ($akm_source | path exists) {
    error make {
      msg: $"AKM source not found at ($akm_source). Create it first, or override via AKM_SOURCE env var."
    }
  }

  let root = ($target | path expand)
  let docs = $"($root)/docs"
  let notes = $"($docs)/notes"
  let daily = $"($notes)/daily"
  let assets = $"($docs)/assets"
  let spec_dir = $"($notes)/spec"

  mkdir $docs $notes $daily $assets $spec_dir

  # Placeholder gitkeeps (no-op if already exist).
  for d in [$notes $daily $assets $spec_dir] {
    let keep = $"($d)/.gitkeep"
    if not ($keep | path exists) { touch $keep }
  }

  # .moxide.toml — markdown-oxide workspace config.
  let moxide = $"($docs)/.moxide.toml"
  if not ($moxide | path exists) {
    let content = '# markdown-oxide PKM workspace config
# Workspace root: ./docs/
# Notes (zettel) live in ./docs/notes/
# Assets live in ./docs/assets/ (managed outside moxide — Obsidian attachmentFolderPath if used)

dailynote = "%Y-%m-%d"

new_file_folder_path = "notes"
daily_notes_folder = "notes/daily"

heading_completions = true
title_headings = true
unresolved_diagnostics = true
semantic_tokens = true

link_filenames_only = true

include_md_extension_md_link = false
include_md_extension_wikilink = false

case_matching = "Smart"

inlay_hints = true
block_transclusion = true
block_transclusion_length = "Full"

excluded_folders = ["assets"]
'
    $content | save --force $moxide
    print $"created: ($moxide)"
  } else {
    print $"kept:    ($moxide)"
  }

  # .markdownlint.json — lint relaxations.
  let lint = $"($docs)/.markdownlint.json"
  if not ($lint | path exists) {
    '{
  "MD022": false,
  "MD032": false
}
' | save --force $lint
    print $"created: ($lint)"
  } else {
    print $"kept:    ($lint)"
  }

  # product.md — hub stub if missing (don't overwrite existing).
  let product = $"($docs)/product.md"
  if not ($product | path exists) {
    let stub = '# Product

Central hub for this PKM. Every typed zettel is reachable from here.

## Stories

_(none yet — add `[[us###|<want clause>]]` under a persona heading)_

## Features

_(none yet — add `[[ft###|<capability>]]` entries when defined)_

## Architecture Decision Records

_(none yet — group `[[adr####]]` entries by `### [[cat###]]`)_

## AKM Reference

- [[akm]] — knowledge model: every zettel type, its schema and life-cycle
'
    $stub | save --force $product
    print $"created: ($product)"
  } else {
    print $"kept:    ($product)"
  }

  # board.md — spec lifecycle index. Sections match sp### status values.
  let board = $"($docs)/board.md"
  if not ($board | path exists) {
    let board_stub = '# Board

Active workstreams. Specs (`sp###`) at `status` ∈ {idea, spec, ready} grouped
under section headings matching their status. Move entries between sections
when status flips; `spec-retro` moves `done` entries into `archive.md`.

## idea

## spec

## ready
'
    $board_stub | save --force $board
    print $"created: ($board)"
  } else {
    # Existing board.md must have the three section headings or
    # `akm create` will silently no-op on board insertion.
    let content = (open --raw $board)
    let missing = (["## idea" "## spec" "## ready"]
      | where { |h| not ($content | str contains $h) })
    if not ($missing | is-empty) {
      print -e $"warn: ($board) missing sections: ($missing | str join ', ')"
      print -e "      `akm create` will not insert sp### links until these exist."
    } else {
      print $"kept:    ($board)"
    }
  }

  # cat### scaffolding — canonical 8-category taxonomy.
  #
  # ADR / Implementation / Feature zettels file under a `[[cat###]]` link in
  # their H1. Without a starting taxonomy each project drifts to its own
  # category names, which makes cross-project zettel reuse harder and adds
  # an extra interview step to every adr-write call. The 8-category default
  # below matches the set converged on in real projects (samples-demo,
  # stock-design-system). Users can rename, supersede, or extend after init.
  #
  # When `docs/notes/` already has cat### files, we keep them (no overwrite)
  # but compare each canonical slot against what's on disk and surface every
  # collision: same id with different alias, missing canonical slots, or
  # non-canonical cat### that occupy ids reserved by the taxonomy. The
  # warnings give the user enough information to decide whether to rename
  # in place, supersede, or extend the canonical set.
  let canonical = (canonical_cats)
  let existing_cats = (glob $"($notes)/cat*.md")
  if ($existing_cats | is-empty) {
    let today = (date now | format date "%Y-%m-%d")
    for entry in ($canonical | enumerate) {
      let n = ($entry.index + 1)
      let id = $"cat(($n) | fill -a r -c '0' -w 3)"
      let f = $"($notes)/($id).md"
      let cat_name = $entry.item
      let content = ([
        "---"
        "aliases:"
        $"  - ($cat_name)"
        "status: stable"
        $"created: ($today)"
        "---"
        ""
        $"# ($cat_name) [[product]]"
        ""
        "## name"
        $cat_name
        ""
        "## summary"
        ""
        "## scope_notes"
        ""
        "---"
        ""
        "Index: [[product]]"
        ""
      ] | str join "\n")
      $content | save -f $f
      print $"created: ($f)"
    }
  } else {
    print $"kept:    ($existing_cats | length) existing cat### zettel(s)"
    check_cat_collisions $notes $canonical
  }

  # akm.md — symlink to canonical source.
  # Use `test -L` so broken symlinks (target moved/renamed) get refreshed
  # instead of blocking the new `ln -s`.
  let akm_link = $"($notes)/akm.md"
  let is_symlink = ((^test -L $akm_link | complete | get exit_code) == 0)
  let is_regular = ((^test -e $akm_link | complete | get exit_code) == 0) and (not $is_symlink)

  if $is_symlink {
    ^rm $akm_link
  } else if $is_regular {
    print $"warn:    ($akm_link) exists as regular file; backing up to akm.md.bak"
    mv $akm_link $"($akm_link).bak"
  }
  ^ln -s $akm_source $akm_link
  print $"linked:  ($akm_link) -> ($akm_source)"

  print ""
  print $"PKM ready under ($docs)."
}

# Upsert a typed zettel — mint a stub if it doesn't exist, leave it alone
# if it does. Returns the resolved id either way so callers (scripts,
# skills) can chain off this without first checking existence.
#
# Why upsert and not strict create: AKM workflows often want "ensure a
# zettel exists for X" without caring whether this run is the first. A
# strict create errored on every retry and pushed users to write
# pre-existence checks at every call site. Upsert is the friendlier
# default; a destructive "rewrite this stub" surface can be added later
# if real demand shows up (today the typed writer skills handle full
# body edits — `akm write` is just id-and-scaffold).
#
# Existence is checked by alias OR id collision via `find_zettel`. When
# the zettel already exists `akm write` is a no-op on disk (frontmatter,
# body, and board.md untouched); only `--session` is special-cased — if
# the existing sp### has no `claude_session_id:` line yet we surface the
# id but do NOT inject one, since that would silently mutate the file.
#
# Type-specific extras:
#   --session   (sp only) mint a claude session id into frontmatter and
#               print a `claude --session-id <id>` resume command. Useful
#               for kicking off a brainstorm in a fresh tmux pane.
def "main write" [
  type: string  # sp | us | pn | ft | im | adr | cat
  name: string  # alphanumeric / dash / underscore — used as the first alias
  --session    # only meaningful for type=sp — mints a claude session id
] {
  if not ($name =~ '^[a-zA-Z0-9_-]+$') {
    error make { msg: "name must contain only alphanumeric characters, dashes, and underscores" }
  }
  let s = (type_schema $type)
  let root = (require_akm_root)

  if ($session and $type != "sp") {
    error make { msg: "--session is only valid for type=sp" }
  }

  # Upsert short-circuit — if any zettel already matches the alias or the
  # caller passed an id form, return that path. No frontmatter rewrite, no
  # board.md re-insertion, no session_id minting.
  let dupe = (find_zettel $root $name)
  if ($dupe != "") {
    let dupe_id = ($dupe | path basename | str replace ".md" "")
    print -e $"Exists ($dupe)"
    if $session {
      let content = (open --raw $dupe)
      let sid = (read_field $content "claude_session_id")
      if ($sid != "") {
        print -e $"Resume cmd: claude --session-id ($sid) -n ($name).($dupe_id)"
      } else {
        print -e "Note: --session ignored on existing sp### with no session id (rewriting frontmatter would be destructive)"
      }
    }
    return
  }

  let id = (next_id $root $type)
  let dir = $"($root)/($s.dir)"
  let f = $"($dir)/($id).md"
  let today = (date now | format date "%Y-%m-%d")

  let session_id = (if $session { (random uuid) } else { "" })

  let fm_base = [
    "---"
    "aliases:"
    $"  - ($name)"
    $"status: ($s.status)"
    $"created: ($today)"
  ]
  let fm = (if ($session_id != "") {
    $fm_base | append $"claude_session_id: ($session_id)"
  } else { $fm_base })

  # Body header — sp lives on the board so its H1 links back to [[board]];
  # other types link back to [[product]] since they live in the typed-zettel
  # navigation hub. Skills may rewrite the H1 (e.g. im### prepends a
  # `[[cat###]]` link); the stub form is just a valid starting point.
  let h1_target = (if $type == "sp" { "[[board]]" } else { "[[product]]" })

  let section_lines = ($s.sections | each { |h| [$h "" ] } | flatten)

  let body = ([
    "---"
    ""
    $"# ($type | str capitalize) ($h1_target)"
    ""
  ]
  | append $section_lines
  | append [
    "---"
    ""
    $"Index: [[($s.index)]]"
    ""
  ])

  ($fm | append $body | str join "\n") | save -f $f
  print -e $"Created ($f)"

  # Only sp registers on docs/board.md ## idea. Other types are reachable
  # via docs/product.md (and via wikilinks from sibling zettels).
  if ($s.board != "") {
    let board = $"($root)/docs/board.md"
    if ($board | path exists) {
      add_to_board_idea $board $id $name
      print -e $"Linked in ($board) ## ($s.board)"
    } else {
      print -e $"warn: ($board) missing — run `akm init ($root)` to scaffold"
    }
  }

  if ($session_id != "") {
    print -e ""
    print -e $"Resume cmd: claude --session-id ($session_id) -n ($name).($id)"
  }
}

# Read the raw markdown of a typed zettel by id ("sp025", "adr0010", ...)
# or first alias. Prints the file content to stdout. Useful for scripts
# and skills that want zettel content via a single resolver — `akm read`
# goes through `require_akm_root` so feature-worktree access refuses the
# same way every other AKM surface does.
def "main read" [
  key: string  # id or first alias
] {
  let root = (require_akm_root)
  let f = (find_zettel $root $key)
  if ($f == "") {
    error make { msg: $"no zettel matching `($key)` (by id or alias)" }
  }
  open --raw $f
}

# Delete any typed zettel + (for sp only) its board.md entry. Accepts an
# id ("sp025", "adr0010", "us003") or a first-alias. Does NOT touch bd —
# bd epic / task lifecycle is the skills' job (spec-retro closes; here we
# just remove the zettel and its board reference if any).
def "main delete" [
  key: string
  --force  # skip confirmation
] {
  let root = (require_akm_root)
  let f = (find_zettel $root $key)
  if ($f == "") {
    error make { msg: $"no zettel matching `($key)` (by id or alias)" }
  }
  let id = ($f | path basename | str replace ".md" "")
  let board = $"($root)/docs/board.md"
  let has_board_entry = (($id | str starts-with "sp") and ($board | path exists))

  if not $force {
    print -e $"Will delete:"
    print -e $"  ($f)"
    if $has_board_entry {
      print -e $"  ($board) entry for ($id)"
    }
    let ans = (input "Proceed? [y/N]: ")
    if ($ans | str lowercase) != "y" {
      print -e "Aborted"
      return
    }
  }

  rm $f
  if $has_board_entry { remove_from_board $board $id }
  print -e $"Deleted ($id)"
}

# Extract `[[cat###]]` wikilinks from a zettel's H1 line. Returns a list
# of cat ids (e.g. ["cat001" "cat002"]) — empty when the zettel has no
# category links in its H1. Skills filter on this column for category-
# scoped queries like "ADRs in cat002" or "Features in cat005".
def read_h1_categories [content: string] {
  let lines = ($content | lines)
  let h1 = ($lines | where { |l| $l | str starts-with "# " } | first)
  if ($h1 == null) { return [] }
  # Capture group inside the brackets — match cat###, return the id only.
  let matches = ($h1 | parse --regex '\[\[(cat\d+)\]\]')
  if ($matches | is-empty) { return [] }
  $matches | get capture0
}

# List zettels grouped by type+status. Pass a type to filter. Frontmatter
# `status` is the source of truth — board.md sections / product.md groupings
# are navigational, not state.
#
# Columns: type, id, name (first alias), status, created, categories.
#
# Default output is a rendered nushell table (good for humans). Pass --json
# to get a JSON array; skills downstream parse it via `from json` and
# filter natively:
#
#   akm list adr --json | from json | where status == 'Accepted'
#   akm list adr --json | from json | where 'cat002' in categories
#   akm list ft  --json | from json | where status == 'stable' | get id
#
# `--json` exists because `akm` is an external command — across process
# boundaries nu only passes text, so structured pipelines need an explicit
# serialization step.
#
# Usage:
#   akm list                 # all types, table
#   akm list sp              # spec lifecycle
#   akm list adr --json      # ADRs as JSON for pipelining
def "main list" [
  type?: string  # one of sp us pn ft im adr cat — omit to list all
  --json        # emit JSON instead of a rendered table (for shell pipelines)
] {
  let root = (require_akm_root)
  let prefixes = (if ($type == null) {
    type_prefixes
  } else {
    [ (type_schema $type | get type) ]
  })

  let rows = ($prefixes | each { |p|
    let s = (type_schema $p)
    let dir = $"($root)/($s.dir)"
    if not ($dir | path exists) { return [] }
    let files = (glob $"($dir)/($p)*.md")
    $files | each { |f|
      let content = (open --raw $f)
      let id = ($f | path basename | str replace ".md" "")
      {
        type: $p
        id: $id
        name: (read_first_alias $content)
        status: (read_field $content "status")
        created: (read_field $content "created")
        categories: (read_h1_categories $content)
      }
    }
  } | flatten)

  if ($rows | is-empty) {
    if $json {
      "[]"
    } else if ($type == null) {
      print "No zettels (empty docs/notes/)"
    } else {
      print $"No ($type)### zettels"
    }
    return
  }

  let sorted = ($rows | sort-by type status id)
  if $json {
    $sorted | to json
  } else {
    $sorted
  }
}

