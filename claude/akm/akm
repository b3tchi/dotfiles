# Add a generated `depends_on_id` mirror of `depends_on_issue_id` on the
# dependencies table. perles (<=0.8.7) queries `depends_on_id`; bd >=1.0.5
# renamed the real column to `depends_on_issue_id`, so every perles BQL
# dependency-join errors and the board renders empty. The STORED generated
# column keeps perles working and auto-syncs for bd-created deps. No-op when
# already present, or when the old schema (real depends_on_id) is in use, or
# when depends_on_issue_id doesn't exist. (auctions recovery 2026-05-30.)
def bd_ensure_perles_compat [] {
  if not (bd_has_table "dependencies") { return false }
  if (bd_has_column "dependencies" "depends_on_id") { return false }
  if not (bd_has_column "dependencies" "depends_on_issue_id") { return false }
  print -e "Adding perles-compat generated column dependencies.depends_on_id..."
  bd_dolt_exec "ALTER TABLE dependencies ADD COLUMN depends_on_id VARCHAR(255) AS (depends_on_issue_id) STORED;"
  true
}

# Apply the per-clone Dolt schema fixups (wisps + perles compat). Idempotent;
# each returns true only when it actually changed something. Commits to Dolt
# when any fixup fired so the change survives server restarts/flushes.
def bd_ensure_schema [] {
  let changed = ([ (bd_ensure_wisps) (bd_ensure_perles_compat) ] | any { |it| $it })
  if $changed {
    bd_dolt_exec "CALL dolt_add('-A'); CALL dolt_commit('-m', 'akm bd doctor: per-clone Dolt schema fixups (wisps / perles compat)');"
  }
  $changed
}

def bd_preflight [] {
  if (which bd | is-empty) {
    error make { msg: "bd (beads) CLI not found on PATH — run infinifu/install.sh" }
  }
  let root = (bd_project_root)
  if not ($"($root)/.beads" | path exists) {
    error make { msg: $"($root)/.beads not found — run 'bd init' from the project root first" }
  }
  bd_strip_hooks $root
  bd_ensure_config
}

