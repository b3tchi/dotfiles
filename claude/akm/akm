  ($fm | append ["---" "" $h1 ""] | append $body_block | append $footer | str join "\n") | save -f $f

  # Register on the board under ## idea (idempotent).
  let board = $"($root)/docs/board.md"
  if ($board | path exists) {
    add_to_board_idea $board $id $name
  } else {
    print -e $"warn: ($board) missing — run `akm init ($root)` to scaffold"
  }

  ^git -C $root add $"docs/notes/spec/($id).md" $"docs/board.md" | ignore

  print $"Id: ($id)"
  print -e $"Path: ($f)"
  print -e $"Staged docs/notes/spec/($id).md + docs/board.md"
  if ($session_id != "") {
    print -e $"Resume cmd: claude --session-id ($session_id) -n ($name).($id)"
  }
}

