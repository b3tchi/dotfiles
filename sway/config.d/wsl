# Clipboard sync: Wayland <-> Windows, fully automatic.
# Both sides poll every 500ms and dedupe via md5 hash at /tmp/clipboard-last-hash.
# Polling (rather than wl-paste --watch) because --watch can silently lose its
# compositor subscription after long uptime — process alive, events dead.
exec flock -n /tmp/clipboard-to-win.lock clipboard-to-win
exec flock -n /tmp/win-clipboard-sync.lock win-clipboard-sync

# Disable Xwayland (WSLg mounts /tmp/.X11-unix read-only, no sticky bit)
xwayland disable

# Extra outputs are managed by sway-session.sh (keepalive pattern)
# exec swaymsg create_output

# Move current workspace to next output (works with dynamic WL-* names)
bindsym Alt+Shift+o move workspace to output right

# Assign workspaces to output
# If output doesn't exist, defaults to WL-1
# workspace 1 output WL-1
# workspace 2 output WL-2
# workspace 3 output WL-1
# workspace 4 output WL-1
# workspace 5 output WL-1
# workspace 6 output WL-1
# workspace 7 output WL-1
# workspace 8 output WL-2
# workspace 9 output WL-2
# workspace 10 output WL-2

