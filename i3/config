# i3 config file (v4)
# Please see http://i3wm.org/docs/userguide.html for a complete reference!

# Set mod key (Mod1=<Alt>, Mod4=<Super>) via X resource with fallback —
# i3 include limitation: vars set in included overlays are invisible to
# this main file, so platform mod comes from xrdb (xrdp xinitrc merges
# "i3wm.mod: Mod1"; native loads nothing → Mod4 fallback)
set_from_resource $mod i3wm.mod Mod4

# Platform overlay (ft003 i3-config-layering): rotz links exactly one of
# i3/config.d/{native,wsl}.conf here. Overlay owns $term + all autostart
# execs + bar; base owns keybinds/workspaces/modes/colors and never execs.
# Include sits at top so overlay vars ($term) resolve before binds below.
include ~/.i3/config.d/*.conf

# set default desktop layout (default is tiling)
# workspace_layout tabbed <stacking|tabbed>
workspace_layout tabbed

# Configure border style <normal|1pixel|pixel xx|none|pixel>
default_border normal 4
default_floating_border normal 4

# Hide borders
hide_edge_borders none

# change borders
bindsym $mod+u border none
bindsym $mod+y border pixel 4
bindsym $mod+n border normal 4

# avoid leaving unfocuse with full screen
popup_during_fullscreen smart

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
# font xft:URWGothic-Book 11
font xft:Iosevka 11

# Use Mouse+$mod to drag floating windows
floating_modifier $mod

#enable tiling tiling
tiling_drag modifier titlebar

# start a terminal with pre-created tmux session
bindsym $mod+Return exec ~/.local/bin/wm-launch-terminal st
# bindsym $mod+Return exec wezterm-gui start --always-new-process

# kill focused window
bindsym $mod+Shift+q kill

# start program launcher
bindsym $mod+Shift+d exec --no-startup-id dmenu_recency
bindsym $mod+d exec ~/.dotfiles/quickshell/qs-overlay.sh launcher

# old rofi launcher (replaced by quickshell AppLauncher)
# bindsym $mod+d exec --no-startup-id rofi -show run
# bindsym $mod+d exec --no-startup-id rofi -show run -theme-str 'entry {placeholder:"run";}'


# launch categorized menu
bindsym $mod+m exec --no-startup-id morc_menu

