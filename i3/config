set $qsbarenv env QS_BAR_INSET_BOTTOM=50 QS_BAR_INSET_AUTO=1
bindsym $mod+Shift+d --release exec --no-startup-id $qsbarenv ~/.dotfiles/quickshell/qs-start.sh
# clipboard-history picker (sp014) — opens the quickshell picker; choosing a
# row puts that entry on the clipboard. It is a PICKER, not a paste tool:
# nothing is typed or injected into the focused window, you still paste
# yourself. Binding lives in the base config because every platform gets the
# picker (the copyq server and the cross-display feeder that back it are
# platform-specific and live in config.d/); qs-clip.sh derives the target
# session itself from the live quickshell instances, so no DISPLAY is passed
# here — and nothing on this line depends on an overlay var, which would be
# invisible across the include boundary anyway.
bindsym $mod+Shift+v exec --no-startup-id ~/.dotfiles/quickshell/qs-clip.sh toggle
bindsym Print exec --no-startup-id i3-scrot
bindsym $mod+Print --release exec --no-startup-id i3-scrot -w
bindsym $mod+Shift+Print --release exec --no-startup-id i3-scrot -s
# region screenshot — enters a "screenshot" i3 mode (shown in the bar like
# resize) and launches the live selector: a GDK window shaped down to the
# rubber-band outline, so the real desktop shows through and nothing is frozen
# or dimmed. Drag or tap two corners; the crop lands in ~/Pictures/screenshots
# and its PATH goes on the clipboard.
# See quickshell/qs-screenshot.sh + quickshell/qs-region.py.
#
# Base, not the platform overlay: every X11 session gets it (native :0, WSL and
# desktop xrdp :10) — stranding the bind in native.conf left WSL unable to
# reach it at all (dotfiles-13q).
#
# The mode exists ONLY so the bar paints its hint strip (Bar.qml modeHints).
# qs-screenshot.sh enters it and resets it on every exit path, so the bind does
# NOT set the mode itself — a bind-set mode would be redundant with the
# launcher's, and the launcher is the one that can guarantee the reset.
#
# The selector holds a pointer+keyboard grab, so it receives the keys directly;
# there are no `w` / drag bindings here. The old ones — and the IPC shim script
# they called — existed only because the retired quickshell dock layer could not
# receive arbitrary keys. Both are gone.
#
# Escape stays as a DEAD-OVERLAY FALLBACK: while the selector lives its grab
# swallows Esc, so this never fires. If the selector dies or never starts, the
# grab is gone, Esc reaches i3, and the mode unsticks instead of trapping the
# session (the dotfiles-ux1 failure class).
mode "screenshot" {
    bindsym Escape mode default
}
bindsym $mod+Shift+s exec --no-startup-id ~/.dotfiles/quickshell/qs-screenshot.sh
bindsym $mod+Shift+h exec xdg-open /usr/share/doc/manjaro/i3_help.pdf
bindsym $mod+Ctrl+x --release exec --no-startup-id xkill

# focus_follows_mouse no

# change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# workspace back and forth (with/without active container)
workspace_auto_back_and_forth yes
# bindsym $mod+b workspace back_and_forth
# bindsym $mod+Shift+b move container to workspace back_and_forth; workspace back_and_forth

# split orientation
bindsym $mod+s split h;exec notify-send 'tile side'
bindsym $mod+b split v;exec notify-send 'tile bellow'
bindsym $mod+q split toggle

# toggle fullscreen mode for the focused container
bindsym $mod+z fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
# bindsym $mod+s layout stacking
bindsym $mod+t layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
# bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
# bindsym $mod+space focus mode_toggle

# toggle sticky (pinned — p, like tmux; $mod+Shift+s is the region screenshot)
bindsym $mod+Shift+p sticky toggle

# focus the parent container
bindsym $mod+a focus parent

# move the currently focused window to the scratchpad
bindsym $mod+Shift+minus move scratchpad

# Show the next scratchpad window or hide the focused scratchpad window.
# If there are multiple scratchpad windows, this command cycles through them.
bindsym $mod+minus scratchpad show

#navigate workspaces next / previous
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Ctrl+Left workspace prev

# Workspace switching by Polybar display order (supports named project workspaces)
set $ws_switch ~/.local/bin/ws-switch.nu

# switch to workspace by display position
bindsym $mod+1 exec --no-startup-id $ws_switch 1
bindsym $mod+2 exec --no-startup-id $ws_switch 2
bindsym $mod+3 exec --no-startup-id $ws_switch 3
bindsym $mod+4 exec --no-startup-id $ws_switch 4
bindsym $mod+5 exec --no-startup-id $ws_switch 5
bindsym $mod+6 exec --no-startup-id $ws_switch 6
bindsym $mod+7 exec --no-startup-id $ws_switch 7
bindsym $mod+8 exec --no-startup-id $ws_switch 8

# Move focused container to workspace by display position
bindsym $mod+Ctrl+1 exec --no-startup-id $ws_switch 1 move
bindsym $mod+Ctrl+2 exec --no-startup-id $ws_switch 2 move
bindsym $mod+Ctrl+3 exec --no-startup-id $ws_switch 3 move
bindsym $mod+Ctrl+4 exec --no-startup-id $ws_switch 4 move
bindsym $mod+Ctrl+5 exec --no-startup-id $ws_switch 5 move
bindsym $mod+Ctrl+6 exec --no-startup-id $ws_switch 6 move
bindsym $mod+Ctrl+7 exec --no-startup-id $ws_switch 7 move
bindsym $mod+Ctrl+8 exec --no-startup-id $ws_switch 8 move

# Move container to workspace and follow
bindsym $mod+Shift+1 exec --no-startup-id $ws_switch 1 follow
bindsym $mod+Shift+2 exec --no-startup-id $ws_switch 2 follow
bindsym $mod+Shift+3 exec --no-startup-id $ws_switch 3 follow
bindsym $mod+Shift+4 exec --no-startup-id $ws_switch 4 follow
bindsym $mod+Shift+5 exec --no-startup-id $ws_switch 5 follow
bindsym $mod+Shift+6 exec --no-startup-id $ws_switch 6 follow
bindsym $mod+Shift+7 exec --no-startup-id $ws_switch 7 follow
bindsym $mod+Shift+8 exec --no-startup-id $ws_switch 8 follow

# Open applications on specific workspaces
# assign [class="Thunderbird"] $ws1
# assign [class="Pale moon"] $ws2
# assign [class="Pcmanfm"] $ws3
# assign [class="Skype"] $ws5

# Open specific applications in floating mode
for_window [all] title_window_icon on
for_window [all] title_window_icon padding 4px

for_window [all] title_format "%title"
# PrusaSlicer: trim version from title ("*file - PrusaSlicer-2.8.1 based on Slic3r" → "*file - PrusaSlicer")
exec_always --no-startup-id pkill -f qs-title-trim; ~/.i3/scripts/qs-title-trim.sh &
for_window [all] border normal 4

for_window [title="qs-launcher"] floating enable, border none, move position center
for_window [title="qs-switcher"] floating enable, border none, move position center
for_window [title="qs-projects"] floating enable, border none, move position center
for_window [title="qs-clip"] floating enable, border none, move position center
# preview-webview client host (sp013): the chrome-less wry window
# (WM_CLASS preview-wv) tiles/docks into the layout by design — no
# floating rule; it sits beside the editor like a split.
# No for_window rule for the region selector: qs-region.py is a GTK POPUP =
# override-redirect, so i3 never manages it and no criteria could ever match.
# (The rule that used to sit here matched title="qs-region" against the OLD
# quickshell dock, which set no title at all — it never matched anything.)
for_window [title="alsamixer"] floating enable border pixel 1
for_window [class="calamares"] floating enable border normal
for_window [class="Clipgrab"] floating enable
for_window [title="File Transfer*"] floating enable
for_window [class="fpakman"] floating enable
for_window [class="Galculator"] floating enable border pixel 1
for_window [class="GParted"] floating enable border normal
for_window [title="i3_help"] floating enable sticky enable border normal
for_window [class="Lightdm-settings"] floating enable
for_window [class="Lxappearance"] floating enable sticky enable border normal
for_window [class="Manjaro-hello"] floating enable
for_window [class="Manjaro Settings Manager"] floating enable border normal
for_window [title="MuseScore: Play Panel"] floating enable
for_window [class="Nitrogen"] floating enable sticky enable border normal
for_window [class="Oblogout"] fullscreen enable
for_window [class="octopi"] floating enable
for_window [title="About Pale Moon"] floating enable
for_window [class="Pamac-manager"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="qt5ct"] floating enable sticky enable border normal
for_window [class="Qtconfig-qt4"] floating enable sticky enable border normal
for_window [class="Simple-scan"] floating enable border normal
for_window [class="(?i)System-config-printer.py"] floating enable border normal
for_window [class="Skype"] floating enable border normal
for_window [class="Timeset-gui"] floating enable border normal
for_window [class="(?i)virtualbox"] floating enable border normal
for_window [class="Xfburn"] floating enable
for_window [title="quickshell-notifications"] floating enable, border none, sticky enable, move position 400 60

# switch to workspace with urgent window automatically
for_window [urgent=latest] focus

# reload the configuration file
bindsym $mod+Shift+c reload

# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# Set shut down, restart and locking features
bindsym $mod+0 mode "$mode_system"
set $mode_system (l)ock, (e)xit, switch_(u)ser, (s)uspend, (h)ibernate, (r)eboot, (Shift+s)hutdown
mode "$mode_system" {
    bindsym l exec --no-startup-id i3exit lock, mode "default"
    bindsym s exec --no-startup-id i3exit suspend, mode "default"
    bindsym u exec --no-startup-id i3exit switch_user, mode "default"
    bindsym e exec --no-startup-id i3exit logout, mode "default"
    bindsym h exec --no-startup-id i3exit hibernate, mode "default"
    bindsym r exec --no-startup-id i3exit reboot, mode "default"
    bindsym Shift+s exec --no-startup-id i3exit shutdown, mode "default"

    # exit system mode: "Enter" or "Escape"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
# Rename workspace
bindsym $mod+Shift+n exec i3-input -f "xft:Iosevka" -F 'name workspace to "%s"' -P 'Workspace name: '

# Project workspace picker (quickshell overlay)
bindsym $mod+p exec --no-startup-id ~/.dotfiles/quickshell/qs-overlay.sh projects

# Resize window (you can also use the mouse for that)
bindsym $mod+r mode "resize"
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode
        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym j resize shrink width 5 px or 5 ppt
        bindsym k resize grow height 5 px or 5 ppt
        bindsym l resize shrink height 5 px or 5 ppt
        bindsym semicolon resize grow width 5 px or 5 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # exit resize mode: Enter or Escape
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

# Lock screen
bindsym $mod+9 exec --no-startup-id blurlock

# quickshell bar + overlay — all platforms (kill+restart on every reload).
# This config also serves xrdp sessions (same machine, DISPLAY :10+); the
# INSET_AUTO pair draws the chin-offset pill only while the viewport is
# phone-shaped (>=2:1 tall, e.g. Razr client), flush bar otherwise —
# reactive across reconnects. ($qsbarenv defined near $mod+Shift+d binding;
# knobs documented in quickshell/config/Common/Session.qml.)
exec_always --no-startup-id $qsbarenv ~/.dotfiles/quickshell/qs-start.sh
# Focus border handled by quickshell (config/FocusBorder.qml);
# clean up legacy xborders fallback
exec_always pkill -f xborders-patched; pkill -x xborders

# Clipboard sync — bridge PRIMARY (mouse-select) <-> CLIPBOARD so terminal
# selections paste into apps that read CLIPBOARD (Claude Code, Ctrl+Shift+V).
# All X11 i3 platforms (native, proot, WSL-i3).
exec_always --no-startup-id pkill -x autocutsel; autocutsel -fork
exec_always --no-startup-id autocutsel -selection PRIMARY -fork

# Other autostarts (wallpaper, compositor, tray apps, lockscreen, keyboard
# layout) live in the platform overlay → config.d/native.conf
